---
import { GITHUB_ORIGIN, defaultLandingStructuredData } from '../site/social';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, Astro.site).href,
  ogType = 'website',
  ogImage = 'https://cinchcli.com/og-image.png',
  noindex = false,
  jsonLd,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Canonical -->
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex,follow" />}

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Cinch" />
  <meta property="og:image" content={ogImage} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#4FB3A9">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href={GITHUB_ORIGIN}>
  <!-- Geist (body · UI · display) + Geist Mono (code · kbd) -->
  <link id="fonts-cinch" rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500;600&family=Geist:wght@400;500;600;700;800&display=swap">
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500;600&family=Geist:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </noscript>
  <script is:inline>
    var fonts = document.getElementById('fonts-cinch');
    if (fonts) fonts.setAttribute('rel', 'stylesheet');
  </script>

  <!-- Analytics -->
  <script is:inline defer src="https://umami.jinmu.me/script.js" data-website-id="9c8818d2-8496-48cd-a55d-81e6e3979078"></script>

  <!-- Structured Data -->
  {jsonLd
    ? <script is:inline type="application/ld+json" set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])} />
    : <script is:inline type="application/ld+json" set:html={JSON.stringify(defaultLandingStructuredData())} />
  }
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <main id="main-content">
    <slot />
  </main>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 300;
    padding: 0.5rem 1rem;
    background: var(--text-1);
    color: var(--bg);
    border-radius: 0 0 8px 8px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: top 0.2s;
  }

  .skip-link:focus {
    top: 0;
  }

  :root {
    /* Enables `light-dark()` CSS function + correct form-control colors */
    color-scheme: light dark;

    /* ─── DARK MODE (default) ─── DESIGN.md §2.2 */
    --bg:           #050505; /* Deep OLED Black */
    --bg-card:      #0e0f10;
    --bg-card-2:    #161719;
    --border:       rgba(255,255,255,0.06);
    --border-hover: rgba(255,255,255,0.12);
    /* Interaction — Deep @ 8% hover, Deep @ 15% selected */
    --hover:        rgba(79,179,169,0.12);
    --selected:     rgba(79,179,169,0.20);
    /* Text */
    --text-1:       #F0EBE0; /* Bone */
    --text-2:       #A1A1A1;
    --text-3:       #6B6B6B;
    /* Porcelain brand — dual token · Deep splits per mode */
    --accent:       #4FB3A9; /* Porcelain Deep */
    --accent-muted: #3E928A;
    --accent-subtle: rgba(79,179,169,0.1);
    --accent-pastel: #BED9D7;
    --accent-on:    #050505;
    /* Typography — Geist UI + Geist Mono */
    --sans:         'Geist', system-ui, -apple-system, sans-serif;
    --body:         'Geist', system-ui, -apple-system, sans-serif;
    --mono:         'Geist Mono', ui-monospace, 'SFMono-Regular', Menlo, Monaco, monospace;
    /* Semantic — success / online */
    --semantic-ok:  light-dark(#16a34a, #4ade80);

    /* ─── High-End Visual Primitives ─── */
    --radius-outer: 2rem;
    --radius-inner: calc(2rem - 0.5rem);
    --padding-section: 8rem;
    --shadow-diffuse: 0 20px 40px -15px rgba(0,0,0,0.1);
    --ease-fluid: cubic-bezier(0.32, 0.72, 0, 1);
  }

  /* ─── LIGHT MODE ─── DESIGN.md §2.3 · follows system preference */
  @media (prefers-color-scheme: light) {
    :root {
      --bg:           #FBFBFA; /* Warm Bone */
      --bg-card:      #FFFFFF;
      --bg-card-2:    #F7F6F3;
      --border:       rgba(0,0,0,0.06);
      --border-hover: rgba(0,0,0,0.12);
      /* Interaction — Pastel carries mug color */
      --hover:        rgba(190,217,215,0.35);
      --selected:     rgba(190,217,215,0.55);
      /* Text */
      --text-1:       #1A1D1E; /* Charcoal */
      --text-2:       #686B6D; /* WCAG AA on warm bone (~5.0:1) */
      --text-3:       #A4A7A9; /* Tint of muted — for low-emphasis only */
      /* Porcelain Deep · Light */
      --accent:       #246C65; /* Deep·Light */
      --accent-muted: #1A524D;
      --accent-subtle: rgba(36,108,101,0.08);
      --accent-on:    #FFFFFF;
      --shadow-diffuse: 0 20px 40px -15px rgba(0,0,0,0.05);
    }
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--body);
    background: var(--bg);
    color: var(--text-1);
    font-feature-settings: 'calt' 1, 'kern' 1, 'liga' 1, 'ss03' 1;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* ─── Typography Utility ─── */
  h1, h2, h3, h4 {
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.1;
  }

  .text-display {
    font-size: clamp(2.5rem, 8vw, 5rem);
    letter-spacing: -0.05em;
  }

  .text-eyebrow {
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 1rem;
    display: inline-block;
  }

  /* ─── Layout Primitives ─── */
  .section-pad {
    padding-top: var(--padding-section);
    padding-bottom: var(--padding-section);
  }

  /* Mobile — 8rem vertical pad reads as dead space at phone heights. */
  @media (max-width: 640px) {
    .section-pad {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }
  }

  .container-wide {
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  @media (max-width: 640px) {
    .container-wide {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }
  }

  /* ─── Double-Bezel (Doppelrand) ─── */
  .bezel-outer {
    background: var(--bg-card-2);
    border: 1px solid var(--border);
    padding: 0.5rem;
    border-radius: var(--radius-outer);
    box-shadow: var(--shadow-diffuse);
  }

  .bezel-inner {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-inner);
    overflow: hidden;
  }

  /* ─── Buttons ─── */
  .btn-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.375rem;
    border-radius: 100px;
    font-family: var(--sans);
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: -0.02em;
    text-decoration: none;
    transition:
      background 0.35s var(--ease-fluid),
      color 0.35s var(--ease-fluid),
      transform 0.35s var(--ease-fluid),
      box-shadow 0.35s var(--ease-fluid),
      border-color 0.35s var(--ease-fluid);
    cursor: pointer;
    border: 1px solid transparent;
    position: relative;
    isolation: isolate;
  }

  .btn-pill.btn-primary {
    color: var(--accent-on);
    background: var(--accent);
    border-color: light-dark(rgba(255, 255, 255, 0.18), rgba(0, 0, 0, 0.12));
    box-shadow:
      inset 0 1px 0 light-dark(rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0.14)),
      0 1px 1px rgba(0, 0, 0, 0.06),
      0 8px 28px -6px rgba(36, 108, 101, 0.28);
  }

  @media (prefers-color-scheme: dark) {
    .btn-pill.btn-primary {
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.12),
        0 1px 2px rgba(0, 0, 0, 0.35),
        0 10px 32px -8px rgba(79, 179, 169, 0.42);
    }
  }

  .btn-pill.btn-primary:hover {
    background: var(--accent-muted);
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 0 light-dark(rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.16)),
      0 2px 4px rgba(0, 0, 0, 0.08),
      0 14px 36px -8px rgba(36, 108, 101, 0.38);
  }

  @media (prefers-color-scheme: dark) {
    .btn-pill.btn-primary:hover {
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.14),
        0 2px 6px rgba(0, 0, 0, 0.45),
        0 16px 40px -10px rgba(79, 179, 169, 0.5);
    }
  }

  .btn-pill.btn-primary:active {
    transform: translateY(0) scale(0.985);
    transition-duration: 0.12s;
  }

  .btn-pill.btn-primary:focus-visible {
    outline: 2px solid var(--accent-pastel);
    outline-offset: 3px;
  }

  .btn-cta-compact {
    padding: 0.5rem 1rem 0.5rem 1.125rem;
    font-size: 0.8125rem;
    gap: 0.375rem;
  }

  .btn-secondary {
    background: var(--bg-card-2);
    color: var(--text-1);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    background: var(--hover);
    border-color: var(--accent-subtle);
  }

  .btn-cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    opacity: 0.92;
    transition: transform 0.35s var(--ease-fluid), opacity 0.35s var(--ease-fluid);
  }

  .btn-pill.btn-primary:hover .btn-cta-icon {
    transform: translateX(3px);
    opacity: 1;
  }


</style>
