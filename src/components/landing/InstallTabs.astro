---
// InstallTabs — OS-aware install widget with sliding segment control
---

<div class="install-card" id="install">

  <!-- ── Platform selector header ── -->
  <div class="card-header">
    <div class="selector" role="tablist" aria-label="Platform">
      <div class="selector-thumb" id="sel-thumb" aria-hidden="true"></div>
      <button class="sel-btn" role="tab" id="tab-macos"   aria-controls="panel-macos"   aria-selected="false" tabindex="-1">
        <svg class="os-icon" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true"><path d="M9.5 1a3.5 3.5 0 0 1-3.3 2.4A3.5 3.5 0 0 1 9.5 1ZM12 9.7c-.4.9-.6 1.3-1.1 2-.7 1-1.8 2.3-3 2.3-1.1 0-1.4-.7-3-.7s-1.9.7-3 .7c-1.2 0-2.2-1.2-3-2.3C-1.6 9.1-.8 5 1.8 3.6A4 4 0 0 1 4 3c1.3 0 2 .7 3 .7 1 0 1.6-.7 3-.7 1 0 2 .5 2.7 1.5A3.5 3.5 0 0 0 11 7.7c.4.6.7 1.3 1 2Z"/></svg>
        macOS
      </button>
      <button class="sel-btn" role="tab" id="tab-linux"   aria-controls="panel-linux"   aria-selected="true"  tabindex="0">
        <svg class="os-icon" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true"><path d="M7 .5C4 .5 1.6 2.9 1.6 6c0 1.8.6 3.2 1.6 4.3.3.4.5.8.5 1.3v.5h5.3v-.5c0-.4.2-.9.5-1.3C10.5 9.2 11 7.8 11 6c0-3-2.3-5.5-4-5.5ZM3.5 7a1 1 0 1 1 2 0 1 1 0 0 1-2 0Zm5 0a1 1 0 1 1 2 0 1 1 0 0 1-2 0ZM4.5 12.5h4v.5a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-.5Z"/></svg>
        Linux
      </button>
      <button class="sel-btn" role="tab" id="tab-windows" aria-controls="panel-windows" aria-selected="false" tabindex="-1">
        <svg class="os-icon" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true"><path d="M1 2.2 6.4 1.5v5.1H1V2.2Zm6.3-.8L13 .5v6.1H7.3V1.4ZM1 7.4h5.4v5.1L1 11.8V7.4Zm6.3 0H13v6.1l-5.7-.9V7.4Z"/></svg>
        Windows
      </button>
    </div>
    <div class="detected-badge" id="detected-badge" aria-live="polite"></div>
  </div>

  <div class="card-sep" aria-hidden="true"></div>

  <!-- ── Panel body ── -->
  <div class="card-body">

    <!-- macOS -->
    <div class="panel" role="tabpanel" id="panel-macos" aria-labelledby="tab-macos" hidden>
      <a class="dmg-btn" id="dmg-btn" href="https://github.com/cinchcli/desktop/releases/latest">
        <span class="dmg-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </span>
        <span class="dmg-label">Download Cinch Desktop</span>
        <span class="dmg-ver" id="dmg-ver" aria-live="polite"></span>
      </a>

      <div class="cmd-divider" aria-hidden="true">
        <span class="divider-rule"></span>
        <span class="divider-label">or via Homebrew</span>
        <span class="divider-rule"></span>
      </div>

      <button class="cmd-row" type="button" aria-label="Copy: brew install cinchcli/tap/cinch" data-copy="brew install cinchcli/tap/cinch">
        <span class="prompt" aria-hidden="true">$</span>
        <code class="cmd-text">brew install cinchcli/tap/cinch</code>
        <span class="copy-wrap" aria-hidden="true">
          <svg class="icon-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          <svg class="icon-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
      </button>

      <p class="panel-meta">Apple Silicon (M1+) &middot; Signed &amp; notarized</p>
    </div>

    <!-- Linux -->
    <div class="panel" role="tabpanel" id="panel-linux" aria-labelledby="tab-linux">
      <button class="cmd-row" type="button" aria-label="Copy install command" data-copy="curl -fsSL https://cinchcli.com/install.sh | sh">
        <span class="prompt" aria-hidden="true">$</span>
        <code class="cmd-text">curl -fsSL https://cinchcli.com/install.sh | sh</code>
        <span class="copy-wrap" aria-hidden="true">
          <svg class="icon-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          <svg class="icon-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
      </button>
      <p class="panel-meta">Debian · Ubuntu · RHEL · Fedora &mdash; <a href="/docs/getting-started/">other options</a></p>
    </div>

    <!-- Windows -->
    <div class="panel" role="tabpanel" id="panel-windows" aria-labelledby="tab-windows" hidden>
      <a class="dmg-btn dmg-btn--ghost" href="https://github.com/cinchcli/cinch/releases/latest">
        <span class="dmg-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </span>
        <span class="dmg-label">Download for Windows</span>
      </a>
      <p class="panel-meta">Extract <code class="inline-code inline-code--sm">.zip</code> &rarr; add <code class="inline-code inline-code--sm">cinch.exe</code> to PATH</p>
    </div>

  </div>
</div>

<style>
  /* ─── Card shell ────────────────────────────────────────── */
  .install-card {
    width: 100%;
    max-width: 560px;
    background: var(--bg-card);
    border: 1px solid color-mix(in srgb, var(--accent) 18%, var(--border-hover));
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--accent) 6%, transparent) inset,
      0 1px 3px light-dark(rgba(0,0,0,0.04), rgba(0,0,0,0.24)),
      0 0 40px -8px color-mix(in srgb, var(--accent) 12%, transparent);
  }

  /* ─── Header ─────────────────────────────────────────────── */
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0.75rem;
    gap: 0.75rem;
  }

  /* ─── Segmented selector ─────────────────────────────────── */
  .selector {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: light-dark(rgba(0,0,0,0.05), rgba(0,0,0,0.35));
    border-radius: 7px;
    padding: 3px;
    flex: 1;
  }

  .selector-thumb {
    position: absolute;
    top: 3px;
    bottom: 3px;
    left: 3px;
    width: calc((100% - 6px) / 3);
    background: var(--bg-card);
    border-radius: 5px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.2), 0 0 0 1px rgba(255,255,255,0.04) inset;
    transition: transform 0.22s cubic-bezier(0.34, 1.28, 0.64, 1);
    pointer-events: none;
    will-change: transform;
  }

  .sel-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    position: relative;
    z-index: 1;
    font-family: var(--sans);
    font-size: 0.725rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--text-3);
    background: transparent;
    border: none;
    border-radius: 4px;
    padding: 0.35rem 0.5rem;
    cursor: pointer;
    transition: color 0.15s;
    white-space: nowrap;
    line-height: 1;
  }

  .sel-btn[aria-selected="true"] {
    color: var(--text-1);
  }

  @media (hover: hover) {
    .sel-btn:not([aria-selected="true"]):hover {
      color: var(--text-2);
    }
  }

  .sel-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .os-icon {
    width: 11px;
    height: 11px;
    flex-shrink: 0;
    opacity: 0.7;
  }

  .sel-btn[aria-selected="true"] .os-icon {
    opacity: 1;
  }

  /* ─── "Detected" badge ──────────────────────────────────── */
  .detected-badge {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--text-3);
    letter-spacing: 0.02em;
    white-space: nowrap;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .detected-badge.visible {
    opacity: 1;
  }

  /* ─── Separator ──────────────────────────────────────────── */
  .card-sep {
    height: 1px;
    background: var(--border);
    margin: 0;
  }

  /* ─── Body ───────────────────────────────────────────────── */
  .card-body {
    padding: 1rem 1.125rem 1.125rem;
  }

  /* ─── Panel ──────────────────────────────────────────────── */
  .panel {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  /* Explicitly override [hidden] since display:flex would otherwise win */
  .panel[hidden] { display: none; }

  /* ─── DMG download button ────────────────────────────────── */
  .dmg-btn {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    background: var(--accent);
    color: var(--accent-on);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    text-decoration: none;
    transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
    border: none;
    cursor: pointer;
    font-family: var(--sans);
  }

  @media (hover: hover) {
    .dmg-btn:hover {
      background: var(--accent-muted);
      box-shadow: 0 4px 16px color-mix(in srgb, var(--accent) 28%, transparent);
    }
  }

  .dmg-btn:active { transform: scale(0.985); }

  .dmg-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .dmg-btn--ghost {
    background: transparent;
    color: var(--text-2);
    border: 1px solid var(--border-hover);
  }

  @media (hover: hover) {
    .dmg-btn--ghost:hover {
      border-color: color-mix(in srgb, var(--accent) 40%, var(--border-hover));
      color: var(--text-1);
      background: var(--hover);
      box-shadow: none;
    }
  }

  .dmg-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .dmg-label {
    font-size: 0.9rem;
    font-weight: 600;
    flex: 1;
  }

  .dmg-ver {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 400;
    opacity: 0.65;
    letter-spacing: 0.02em;
    margin-left: auto;
  }

  /* ─── Cmd divider ────────────────────────────────────────── */
  .cmd-divider {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0 0.125rem;
  }

  .divider-rule {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .divider-label {
    font-family: var(--sans);
    font-size: 0.68rem;
    color: var(--text-3);
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  /* ─── Command row ────────────────────────────────────────── */
  .cmd-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    width: 100%;
    background: light-dark(rgba(0,0,0,0.04), rgba(0,0,0,0.3));
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.7rem 0.75rem 0.7rem 1rem;
    font-family: var(--mono);
    font-size: 0.8375rem;
    cursor: pointer;
    text-align: left;
    transition: border-color 0.15s, background 0.15s;
    color: inherit;
  }

  @media (hover: hover) {
    .cmd-row:hover {
      border-color: color-mix(in srgb, var(--accent) 35%, var(--border-hover));
      background: light-dark(rgba(0,0,0,0.06), rgba(0,0,0,0.4));
    }

    .cmd-row:hover .copy-wrap {
      opacity: 1;
    }
  }

  .cmd-row:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .prompt {
    color: var(--accent);
    flex-shrink: 0;
    font-weight: 600;
    font-size: 0.875rem;
    line-height: 1;
    user-select: none;
  }

  .cmd-text {
    color: var(--text-2);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    background: none;
    font-family: inherit;
    font-size: inherit;
    font-weight: 400;
  }

  .copy-wrap {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    color: var(--text-3);
    opacity: 0.5;
    transition: opacity 0.15s, color 0.15s;
  }

  .copy-wrap .icon-check {
    color: var(--accent);
  }

  /* ─── Panel meta ─────────────────────────────────────────── */
  .panel-meta {
    font-family: var(--sans);
    font-size: 0.72rem;
    color: var(--text-3);
    line-height: 1.5;
    padding: 0 0.125rem;
  }

  .panel-meta a {
    color: var(--text-3);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: var(--border-hover);
    transition: color 0.15s;
  }

  @media (hover: hover) {
    .panel-meta a:hover { color: var(--text-2); }
  }

  /* ─── Responsive ─────────────────────────────────────────── */
  @media (max-width: 640px) {
    .card-body {
      padding: 0.875rem;
    }

    .detected-badge {
      display: none;
    }

    .cmd-text {
      font-size: 0.75rem;
    }

    .sel-btn {
      font-size: 0.7rem;
      gap: 0.25rem;
      padding: 0.35rem 0.35rem;
    }

    .os-icon {
      display: none;
    }
  }
</style>

<script is:inline>
  (function () {

    function detectOS() {
      var d = navigator.userAgentData;
      if (d && d.platform) {
        var p = d.platform.toLowerCase();
        if (p.indexOf('mac') !== -1) return 'macos';
        if (p.indexOf('win') !== -1) return 'windows';
        if (p.indexOf('linux') !== -1 || p.indexOf('chrome os') !== -1) return 'linux';
      }
      var ua = navigator.userAgent;
      var nav = /** @type {any} */ (navigator);
      var pl = nav.platform || '';
      if (/Mac|iPhone|iPad/i.test(pl) || /Macintosh/i.test(ua)) return 'macos';
      if (/Win/i.test(pl) || /Windows/i.test(ua)) return 'windows';
      return 'linux';
    }

    var OS = ['macos', 'linux', 'windows'];
    var thumb = document.getElementById('sel-thumb');
    var detectedBadge = document.getElementById('detected-badge');

    function moveThumb(idx) {
      if (thumb) thumb.style.transform = 'translateX(' + (idx * 100) + '%)';
    }

    function activate(os, isAuto) {
      var idx = OS.indexOf(os);
      OS.forEach(function (id, i) {
        var btn = document.getElementById('tab-' + id);
        var panel = document.getElementById('panel-' + id);
        var active = i === idx;
        if (btn) {
          btn.setAttribute('aria-selected', String(active));
          btn.setAttribute('tabindex', active ? '0' : '-1');
        }
        if (panel) panel.hidden = !active;
      });
      moveThumb(idx);

      if (isAuto && detectedBadge) {
        var labels = { macos: 'macOS', linux: 'Linux', windows: 'Windows' };
        detectedBadge.textContent = 'detected: ' + labels[os];
        setTimeout(function () { detectedBadge.classList.add('visible'); }, 120);
      }
    }

    // Hydrate
    var detectedOs = detectOS();
    activate(detectedOs, true);

    // Tab interaction + keyboard nav
    OS.forEach(function (id) {
      var btn = document.getElementById('tab-' + id);
      if (!btn) return;

      btn.addEventListener('click', function () {
        activate(id, false);
        if (detectedBadge) {
          detectedBadge.classList.remove('visible');
          detectedBadge.textContent = '';
        }
      });

      btn.addEventListener('keydown', function (e) {
        var cur = OS.indexOf(id);
        var target = null;
        if (e.key === 'ArrowRight') target = OS[(cur + 1) % 3];
        if (e.key === 'ArrowLeft')  target = OS[(cur + 2) % 3];
        if (e.key === 'Home')       target = OS[0];
        if (e.key === 'End')        target = OS[2];
        if (target) {
          e.preventDefault();
          activate(target, false);
          var el = document.getElementById('tab-' + target);
          if (el) el.focus();
        }
      });
    });

    // Fetch latest Desktop version
    var dmgBtn = document.getElementById('dmg-btn');
    var dmgVer = document.getElementById('dmg-ver');
    if (dmgBtn && dmgVer) {
      var ac = typeof AbortController !== 'undefined' ? new AbortController() : null;
      var t = setTimeout(function () { if (ac) ac.abort(); }, 5000);
      fetch('https://github.com/cinchcli/desktop/releases/latest/download/latest.json', {
        signal: ac ? ac.signal : undefined,
        cache: 'force-cache'
      })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (j) {
          clearTimeout(t);
          if (!j || !j.version) return;
          var v = j.version;
          dmgBtn.href = 'https://github.com/cinchcli/desktop/releases/download/desktop-v' + v + '/Cinch_' + v + '_aarch64.dmg';
          dmgVer.textContent = 'v' + v;
        })
        .catch(function () {});
    }

    // Click-to-copy on all cmd-rows
    document.querySelectorAll('.cmd-row[data-copy]').forEach(function (row) {
      var cmd = row.dataset.copy;
      if (!cmd) return;
      var ic = row.querySelector('.icon-copy');
      var ck = row.querySelector('.icon-check');

      row.addEventListener('click', function () {
        navigator.clipboard.writeText(cmd).then(function () {
          if (ic) ic.style.display = 'none';
          if (ck) ck.style.display = '';
          setTimeout(function () {
            if (ic) ic.style.display = '';
            if (ck) ck.style.display = 'none';
          }, 2000);
        }).catch(function () {});
      });
    });

  })();
</script>
