---
// UseCases — High-End Sequential Workflow Section
import TerminalWindow from './TerminalWindow.astro';
---

<section class="usecases section-pad" id="use-cases" aria-labelledby="usecases-heading">
  <div class="container-wide">
    <div class="uc-header animate-in">
      <h2 class="text-display">In practice</h2>
      <p class="uc-header-desc">
        Three moments remote-to-local copy-paste used to need a workaround.
      </p>
    </div>

    <div class="uc-rows">
      <!-- Row 01: SSH sessions -->
      <article class="uc-row" data-uc>
        <div class="uc-info">
          <div class="uc-marker">
            <span class="uc-dot"></span>
            <div class="uc-line"></div>
          </div>
          <div class="uc-content">
            <span class="uc-num">01</span>
            <h3 class="uc-title">SSH sessions</h3>
            <p class="uc-desc">Pipe anything into <code class="inline-code">cinch push</code> — it surfaces on your local machine. No scp, no port forwarding.</p>
          </div>
        </div>
        <div class="uc-visual">
          <TerminalWindow title="prod-server — ssh">
            <div class="term-body">
              <div class="term-line"><span class="t-c">user@prod:~$</span> <span class="t-cmd">cat</span> deploy.log <span class="t-op">|</span> <span class="t-cmd">cinch push</span></div>
              <div class="term-line t-ok">✓ pushed 148 bytes → relay</div>
              <div class="term-line"></div>
              <div class="term-line"><span class="t-c">user@prod:~$</span> <span class="t-cmd">cinch push</span> &lt; config.yaml</div>
              <div class="term-line t-ok">✓ pushed 4.8 KB — config.yaml</div>
            </div>
          </TerminalWindow>
        </div>
      </article>

      <!-- Row 02: Vim & Neovim -->
      <article class="uc-row" data-uc>
        <div class="uc-info">
          <div class="uc-marker">
            <span class="uc-dot"></span>
            <div class="uc-line"></div>
          </div>
          <div class="uc-content">
            <span class="uc-num">02</span>
            <h3 class="uc-title">Vim &amp; Neovim</h3>
            <p class="uc-desc">Yank in Vim and it's on every device. cinch.vim hooks <code class="inline-code">TextYankPost</code> — zero extra keystrokes.</p>
          </div>
        </div>
        <div class="uc-visual">
          <TerminalWindow title="nvim — init.lua">
            <div class="term-body">
              <div class="term-line"><span class="t-c">-- lazy.nvim plugin setup</span></div>
              <div class="term-line"><span class="t-val">&#123; </span><span class="t-str">"cinchcli/cinch.vim"</span><span class="t-val"> &#125;</span></div>
              <div class="term-line"></div>
              <div class="term-line"><span class="t-c">-- yank any motion → auto-pushed</span></div>
              <div class="term-line"><span class="t-cmd">yy</span> <span class="t-meta">" current line</span></div>
              <div class="term-line t-ok">✓ pushed 42 bytes · clip #7</div>
            </div>
          </TerminalWindow>
        </div>
      </article>

      <!-- Row 03: tmux & screen -->
      <article class="uc-row" data-uc>
        <div class="uc-info">
          <div class="uc-marker">
            <span class="uc-dot"></span>
          </div>
          <div class="uc-content">
            <span class="uc-num">03</span>
            <h3 class="uc-title">tmux &amp; screen</h3>
            <p class="uc-desc">Even nested inside ssh → tmux → Vim, cinch.vim pushes every yank over HTTPS — from any pane.</p>
          </div>
        </div>
        <div class="uc-visual">
          <TerminalWindow title="session — tmux · nvim">
            <div class="term-body">
              <div class="term-line"><span class="t-meta">1</span> <span class="t-cmd">use</span> <span class="t-val">axum</span><span class="t-op">::</span><span class="t-val">Router</span><span class="t-op">;</span></div>
              <div class="term-line"><span class="t-meta">2</span> </div>
              <div class="term-line"><span class="t-meta">3</span> <span class="t-cmd">pub fn</span> <span class="t-val">app</span><span class="t-op">()</span> <span class="t-op">-&gt;</span> <span class="t-val">Router</span> <span class="t-op">&#123;</span></div>
              <div class="term-line"><span class="t-meta">NORMAL</span>  <span class="t-val">api/src/lib.rs</span> <span class="t-ok">✓ cinch.vim</span></div>
            </div>
          </TerminalWindow>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .usecases {
    position: relative;
    overflow: hidden;
  }

  .uc-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 8rem;
  }

  .uc-header-desc {
    font-size: 1.25rem;
    color: var(--text-2);
    margin-top: 1.5rem;
    line-height: 1.6;
  }

  .uc-rows {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .uc-row {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 8rem;
    align-items: center;
    padding: 6rem 0;
    opacity: 0;
    transform: translateY(4rem);
    transition: all 1s var(--ease-fluid);
  }

  .uc-row.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .uc-info {
    display: flex;
    gap: 3rem;
    height: 100%;
  }

  .uc-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 20px;
    padding-top: 0.5rem;
  }

  .uc-dot {
    width: 12px;
    height: 12px;
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 20px var(--accent-subtle);
    flex-shrink: 0;
    z-index: 2;
  }

  .uc-line {
    width: 1px;
    flex: 1;
    background: linear-gradient(to bottom, var(--accent) 0%, transparent 100%);
    opacity: 0.2;
    margin-top: 1rem;
    margin-bottom: -6rem; /* Overlap with next row */
  }

  .uc-content {
    padding-bottom: 2rem;
  }

  .uc-num {
    font-family: var(--mono);
    font-size: 0.875rem;
    color: var(--accent);
    font-weight: 700;
    display: block;
    margin-bottom: 1.25rem;
    letter-spacing: 0.1em;
  }

  .uc-title {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.04em;
  }

  .uc-desc {
    font-size: 1.125rem;
    color: var(--text-2);
    line-height: 1.6;
    max-width: 42ch;
  }

  .visual-wrapper {
    padding: 0.625rem;
    background: light-dark(rgba(255,255,255,0.4), rgba(0,0,0,0.4));
    backdrop-filter: blur(10px);
  }

  .uc-terminal {
    background: #0e0f10 !important;
    border: 1px solid rgba(255,255,255,0.05) !important;
  }

  .term-line {
    display: block;
    font-family: var(--mono);
    font-size: 0.875rem;
    line-height: 2;
    white-space: nowrap;
  }

  @media (max-width: 1024px) {
    .uc-row {
      grid-template-columns: 1fr;
      gap: 4rem;
      padding: 4rem 0;
    }
    .uc-info {
      gap: 2rem;
    }
    .uc-line {
      display: none;
    }
    .uc-title {
      font-size: 2rem;
    }
  }

  /* Phone — fold the marker column away so body copy gets the full row width.
     The "01 / 02 / 03" number plus the section's running rhythm already cue ordering;
     a tiny dot in the gutter just steals 50–70px and clips the description. */
  @media (max-width: 640px) {
    .uc-rows {
      gap: 0;
    }
    .uc-row {
      gap: 2rem;
      padding: 2.5rem 0;
    }
    .uc-info {
      display: block;
      gap: 0;
    }
    .uc-marker {
      display: none;
    }
    .uc-content {
      padding-bottom: 0;
    }
    .uc-num {
      margin-bottom: 0.75rem;
    }
    .uc-title {
      font-size: 1.625rem;
    }
    .uc-desc {
      font-size: 1rem;
      max-width: none;
    }

    /* Terminals in this section share the same nowrap-on-overflow problem as LiveWire.
       Shrink padding + font so the lines fit; allow horizontal scroll as a graceful fallback. */
    .uc-visual :global(.term-body) {
      padding: 1.25rem 1rem;
      font-size: 0.75rem;
      line-height: 1.7;
      overflow-x: auto;
    }
    .term-line {
      font-size: inherit;
      line-height: inherit;
    }
  }
</style>

<script>
  if (typeof IntersectionObserver !== 'undefined') {
    const rows = document.querySelectorAll<HTMLElement>('[data-uc]');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      },
      { threshold: 0.1 }
    );
    rows.forEach(row => observer.observe(row));
  }
</script>
