---
// UseCases — Step Line scroll section
// Layout: 2-col grid (text left, terminal right)
// Style: vertical teal spine with node dots per variant C
---

<section class="usecases" aria-labelledby="usecases-heading">
  <div class="uc-inner">

    <header class="uc-header">
      <p class="uc-eyebrow" id="usecases-heading">
        <span class="uc-eyebrow-rule" aria-hidden="true"></span>
        WORKS EVERYWHERE YOU CODE
      </p>
    </header>

    <div class="uc-rows">

      <!-- Row 01: SSH sessions -->
      <article class="uc-row" data-uc>
        <div class="uc-left">
          <div class="uc-marker" aria-hidden="true">
            <span class="uc-dot"></span>
          </div>
          <div class="uc-text">
            <span class="uc-num">01</span>
            <h3 class="uc-title">SSH sessions</h3>
            <p class="uc-desc">Run cinch on any remote server. Push a file, a command output, or raw text — it surfaces instantly on your local machine. No port forwarding, no scp gymnastics.</p>
          </div>
        </div>
        <div class="uc-right">
          <div class="term-window">
            <div class="term-bar">
              <span class="dot dot-r" aria-hidden="true"></span>
              <span class="dot dot-y" aria-hidden="true"></span>
              <span class="dot dot-g" aria-hidden="true"></span>
              <span class="term-title">prod-server — ssh</span>
            </div>
            <pre class="term-body" role="img" aria-label="SSH session push example"><code
><span class="tc">user@prod:~$</span> <span class="tk">cat</span> deploy.log <span class="tp">|</span> <span class="tk">cinch push</span>
<span class="ts">✓ pushed</span>  <span class="tv">148 bytes → relay</span>

<span class="tc">user@prod:~$</span> <span class="tk">cinch push</span> &lt; /etc/nginx/nginx.conf
<span class="ts">✓ pushed</span>  <span class="tv">4.8 KB — nginx.conf</span></code></pre>
          </div>
        </div>
      </article>

      <!-- Row 02: Vim & Neovim -->
      <article class="uc-row" data-uc>
        <div class="uc-left">
          <div class="uc-marker" aria-hidden="true">
            <span class="uc-dot"></span>
          </div>
          <div class="uc-text">
            <span class="uc-num">02</span>
            <h3 class="uc-title">Vim &amp; Neovim</h3>
            <p class="uc-desc">Yank in Vim and the text is already on your clipboard, everywhere. The cinch.vim plugin hooks into <code>TextYankPost</code> — no extra keystrokes required.</p>
          </div>
        </div>
        <div class="uc-right">
          <div class="term-window">
            <div class="term-bar">
              <span class="dot dot-r" aria-hidden="true"></span>
              <span class="dot dot-y" aria-hidden="true"></span>
              <span class="dot dot-g" aria-hidden="true"></span>
              <span class="term-title">nvim — init.lua</span>
            </div>
            <pre class="term-body" role="img" aria-label="Neovim cinch.vim plugin example"><code
><span class="tc"># lazy.nvim</span>
<span class="tv">&#123; </span><span class="ts">"cinchcli/cinch.vim"</span><span class="tv"> &#125;</span>

<span class="tc"># yank any motion → auto-pushed</span>
<span class="tk">yy</span>   <span class="tc">" current line</span>
<span class="tk">yi"</span>  <span class="tc">" inside quotes</span>
<span class="ts">✓ pushed</span>  <span class="tv">42 bytes · clip #7</span></code></pre>
          </div>
        </div>
      </article>

      <!-- Row 03: tmux & screen -->
      <article class="uc-row" data-uc>
        <div class="uc-left">
          <div class="uc-marker" aria-hidden="true">
            <span class="uc-dot"></span>
          </div>
          <div class="uc-text">
            <span class="uc-num">03</span>
            <h3 class="uc-title">tmux &amp; screen</h3>
            <p class="uc-desc">Works inside any multiplexer. OSC 52 breaks in tmux — cinch doesn't. Plain HTTP from any pane, any nesting level.</p>
          </div>
        </div>
        <div class="uc-right">
          <div class="term-window">
            <div class="term-bar">
              <span class="dot dot-r" aria-hidden="true"></span>
              <span class="dot dot-y" aria-hidden="true"></span>
              <span class="dot dot-g" aria-hidden="true"></span>
              <span class="term-title">local — tmux 0:1</span>
            </div>
            <pre class="term-body" role="img" aria-label="tmux push and pull example"><code
><span class="tc">~/project $</span> <span class="tk">cinch push</span> &lt; config.json
<span class="ts">✓ pushed</span>  <span class="tv">512 bytes · clip #14</span>
<span class="tc">─── pane 0 ──────────── pane 1 ───</span>
<span class="tc">~/project $</span> <span class="tk">cinch pull</span>
<span class="ts">✓ pulled</span>  <span class="tv">512 bytes → clipboard</span></code></pre>
          </div>
        </div>
      </article>

    </div><!-- /uc-rows -->
  </div>
</section>

<style>
  /* ── Section wrapper ──────────────────────────────────── */
  .usecases {
    border-top: 1px solid var(--border);
    padding: 5rem 2rem 7rem;
  }

  .uc-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Eyebrow ──────────────────────────────────────────── */
  .uc-header {
    margin-bottom: 3.5rem;
  }

  .uc-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .uc-eyebrow-rule {
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--accent);
    opacity: 0.6;
    flex-shrink: 0;
  }

  /* ── Rows container — holds the spine line ───────────── */
  .uc-rows {
    --dot-col-w: 2.5rem;
    --spine-x: calc(var(--dot-col-w) / 2);
    position: relative;
  }

  /* Spine: single teal line running through all rows */
  .uc-rows::before {
    content: '';
    position: absolute;
    left: var(--spine-x);
    top: 0;
    bottom: 0;
    width: 1px;
    transform: translateX(-0.5px);
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(79,179,169,0.45) 6%,
      rgba(79,179,169,0.45) 94%,
      transparent 100%
    );
    pointer-events: none;
  }

  /* ── Row ──────────────────────────────────────────────── */
  .uc-row {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 4rem;
    padding: 4.5rem 0;
    border-top: 1px solid var(--border);
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  .uc-row.is-visible {
    opacity: 1;
    transform: none;
  }

  /* ── Left column ──────────────────────────────────────── */
  .uc-left {
    display: flex;
    gap: 1.25rem;
  }

  /* Marker column — holds the node dot, aligned with spine */
  .uc-marker {
    width: var(--dot-col-w);
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    padding-top: 0.25rem;
  }

  .uc-dot {
    display: block;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px rgba(79,179,169,0.5);
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }

  /* Text content */
  .uc-text {
    flex: 1;
    min-width: 0;
  }

  .uc-num {
    display: block;
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: var(--accent);
    letter-spacing: 0.06em;
    margin-bottom: 0.625rem;
  }

  .uc-title {
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-1);
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .uc-desc {
    font-size: 0.9375rem;
    color: var(--text-2);
    line-height: 1.75;
    letter-spacing: 0.1px;
    max-width: 38ch;
  }

  .uc-desc code {
    font-family: var(--mono);
    font-size: 0.875em;
    color: var(--accent);
    background: rgba(79,179,169,0.08);
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }

  /* ── Right column — terminal ──────────────────────────── */
  .uc-right {
    min-width: 0;
  }

  .term-window {
    background: #1a1b1e;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(0,0,0,0.12),
      0 4px 12px rgba(0,0,0,0.18),
      0 24px 56px -12px rgba(0,0,0,0.38),
      inset 0 1px 0 rgba(255,255,255,0.04);
  }

  .term-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.625rem 1rem;
    background: rgba(255,255,255,0.025);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-r { background: #ff5f57; }
  .dot-y { background: #febc2e; }
  .dot-g { background: #28c840; }

  .term-title {
    margin-left: auto;
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.28);
    letter-spacing: 0.04em;
  }

  .term-body {
    margin: 0;
    padding: 1.375rem 1.625rem 1.5rem;
    font-family: var(--mono);
    font-size: 0.875rem;
    line-height: 1.85;
    background: transparent;
    overflow-x: auto;
  }

  .term-body code {
    display: block;
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
    white-space: pre;
  }

  /* Syntax tokens */
  .tc { color: rgba(255,255,255,0.28); }
  .tk { color: rgba(255,255,255,0.82); }
  .tp { color: #4FB3A9; }
  .ts { color: #4ade80; }
  .tv { color: rgba(255,255,255,0.58); }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 860px) {
    .usecases {
      padding: 4rem 1.5rem 5rem;
    }

    .uc-row {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .uc-rows::before {
      display: none;
    }

    .uc-marker {
      display: none;
    }

    .uc-left {
      gap: 0;
    }
  }

  @media (max-width: 480px) {
    .term-body {
      font-size: 0.8125rem;
      padding: 1rem 1.25rem 1.125rem;
    }
  }
</style>

<script>
  if (typeof IntersectionObserver !== 'undefined') {
    const rows = document.querySelectorAll<HTMLElement>('[data-uc]');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    rows.forEach(row => observer.observe(row));
  } else {
    document.querySelectorAll<HTMLElement>('[data-uc]').forEach(r => r.classList.add('is-visible'));
  }
</script>
