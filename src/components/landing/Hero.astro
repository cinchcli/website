---
// Hero — left-aligned: headline → description → CTAs → live demo
import LiveWire from './LiveWire.astro';
---

<section class="hero" aria-label="Cinch introduction">
  <!-- Headline -->
  <h1 class="hero-title">
    Your clipboard.
    <span class="title-muted">Across every machine.</span>
  </h1>

  <!-- Description -->
  <p class="hero-description">
    Run <code class="inline-code">cinch push</code> on one machine, <code class="inline-code">cinch pull</code> on any other.
    Text, code, and data — from your terminal or the desktop app.
  </p>

  <!-- CTAs -->
  <div class="hero-actions">
    <div class="hero-ctas">
      <a href="/download" class="cta-download">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download
      </a>
      <a href="/docs/getting-started/" class="cta-docs">
        View docs →
      </a>
    </div>
  </div>

  <!-- Live demo -->
  <div class="hero-demo">
    <LiveWire />
  </div>

</section>

<style>
  /* ─── Section ───────────────────────────────────────── */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    text-align: left;
    padding: 5.5rem 2rem 4rem;
    min-height: 100svh;
    max-width: 1100px;
    margin: 0 auto;
    gap: 0;
  }

  /* ─── Badge ─────────────────────────────────────────── */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.875rem;
    color: var(--text-3);
    letter-spacing: 0.06em;
    margin-bottom: 1.5rem;
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--border-hover);
    border-radius: 100px;
    background: light-dark(rgba(47,127,120,0.06), rgba(79,179,169,0.07));
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    animation: dot-pulse 2.4s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.72); }
  }

  @media (prefers-reduced-motion: reduce) {
    .badge-dot { animation: none; }
  }

  /* ─── Headline ──────────────────────────────────────── */
  .hero-title {
    /* Use Geist for display: engineered + distinctive, not on blocklist */
    font-family: 'Geist', var(--sans);
    font-size: clamp(2.75rem, 5.5vw, 4.25rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
    color: var(--text-1);
    text-wrap: balance;
    margin-bottom: 1.25rem;
    max-width: 18ch;
    /* Disable common ligatures on display weight */
    font-feature-settings: 'liga' 0, 'calt' 1;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }

  .title-muted {
    color: var(--text-2);
  }

  /* ─── Description ───────────────────────────────────── */
  .hero-description {
    font-family: var(--sans);
    font-size: 1.0625rem;
    color: var(--text-2);
    line-height: 1.7;
    font-weight: 400;
    letter-spacing: 0.1px;
    max-width: 52ch;
    text-wrap: pretty;
    margin-bottom: 1.75rem;
  }

  /* ─── Actions row ───────────────────────────────────── */
  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.875rem;
    margin-bottom: 3rem;
    width: 100%;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  /* Primary download CTA */
  .cta-download {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent);
    color: var(--accent-on);
    font-family: var(--sans);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    padding: 0.75rem 1.375rem;
    border-radius: 8px;
    text-decoration: none;
    box-shadow: 0 1px 2px color-mix(in srgb, var(--accent) 14%, transparent);
    transition: background 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1), transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (hover: hover) {
    .cta-download:hover {
      background: var(--accent-muted);
      box-shadow: 0 4px 20px color-mix(in srgb, var(--accent) 28%, transparent);
      transform: translateY(-1px);
    }
  }

  .cta-download:active { transform: translateY(1px) scale(0.98); }

  @media (prefers-reduced-motion: reduce) {
    .cta-download:hover,
    .cta-download:active { transform: none; }
  }

  .cta-download:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* Secondary docs link */
  .cta-docs {
    font-family: var(--sans);
    font-size: 0.875rem;
    color: var(--text-3);
    text-decoration: none;
    letter-spacing: 0.01em;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: color 0.15s;
  }

  @media (hover: hover) {
    .cta-docs:hover { color: var(--text-2); }
  }

  .cta-docs:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* ─── Live demo ─────────────────────────────────────── */
  .hero-demo {
    position: relative;
    width: 100%;
  }

  /* Editorial ambient: soft warm light behind the terminals.
     Pure decoration — pointer-events:none, very low opacity. */
  .hero-demo::before {
    content: '';
    position: absolute;
    inset: -10% -8%;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 60% 50% at 25% 50%,
        light-dark(rgba(47,127,120,0.05), rgba(79,179,169,0.05)),
        transparent 70%),
      radial-gradient(ellipse 50% 50% at 80% 60%,
        light-dark(rgba(155,154,150,0.04), rgba(255,255,255,0.02)),
        transparent 70%);
  }

  /* ─── Responsive ────────────────────────────────────── */
  @media (max-width: 640px) {
    .hero {
      padding: 7rem 1.25rem 4rem;
      min-height: auto;
    }
  }
</style>

