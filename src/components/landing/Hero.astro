---
// Hero — centered: badge → headline → description → install strip → live demo
import LiveDemo from './LiveDemo.astro';
---

<section class="hero" aria-label="Cinch introduction">

  <!-- Badge -->
  <p class="hero-badge">
    <span class="badge-dot" aria-hidden="true"></span>
    AGPL 3.0 · Open source
  </p>

  <!-- Headline -->
  <h1 class="hero-title">
    Copy from any terminal.
    <span class="title-muted">Paste anywhere.</span>
  </h1>

  <!-- Description -->
  <p class="hero-description">
    Push text, code, or data from any terminal — pull it instantly on any other machine.
    No GUI required.
  </p>

  <!-- Install strip + CTA -->
  <div class="hero-actions">
    <div
      class="install-strip"
      id="install-strip"
      role="button"
      tabindex="0"
      aria-label="Install command — click to copy"
    >
      <span class="dollar">$</span>
      <span class="cmd">curl -fsSL https://cinchcli.com/install.sh | sh</span>
      <button class="copy-btn" id="copy-btn" aria-label="Copy install command" type="button">
        <svg id="icon-copy" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <svg id="icon-check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </button>
    </div>

    <a href="/docs/getting-started/" class="btn-primary">
      Get started
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>

  <!-- Interactive live demo -->
  <div class="hero-terminals">
    <LiveDemo />
  </div>

</section>

<style>
  /* ─── Section ───────────────────────────────────────── */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 5.5rem 2rem 4rem;
    min-height: 100svh;
    max-width: 1100px;
    margin: 0 auto;
    gap: 0;
  }

  /* ─── Badge ─────────────────────────────────────────── */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-3);
    letter-spacing: 0.06em;
    margin-bottom: 1.5rem;
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--border-hover);
    border-radius: 100px;
    background: light-dark(rgba(47,127,120,0.06), rgba(79,179,169,0.07));
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    animation: dot-pulse 2.4s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.72); }
  }

  @media (prefers-reduced-motion: reduce) {
    .badge-dot { animation: none; }
  }

  /* ─── Headline ──────────────────────────────────────── */
  .hero-title {
    /* Use Geist for display: engineered + distinctive, not on blocklist */
    font-family: 'Geist', var(--sans);
    font-size: clamp(2.75rem, 5.5vw, 4.25rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
    color: var(--text-1);
    text-wrap: balance;
    margin-bottom: 1.25rem;
    /* Disable common ligatures on display weight */
    font-feature-settings: 'liga' 0, 'calt' 1;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }

  .title-muted {
    color: var(--text-2);
  }

  /* ─── Description ───────────────────────────────────── */
  .hero-description {
    font-family: var(--sans);
    font-size: 1.0625rem;
    color: var(--text-2);
    line-height: 1.7;
    font-weight: 400;
    letter-spacing: 0.1px;
    max-width: 52ch;
    text-wrap: pretty;
    margin-bottom: 1.75rem;
  }

  /* ─── Actions row ───────────────────────────────────── */
  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  /* Install strip */
  .install-strip {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    background: var(--bg-card);
    border: 1px solid var(--border-hover);
    border-radius: 8px;
    padding: 0.625rem 0.75rem 0.625rem 1rem;
    font-family: var(--mono);
    font-size: 0.8125rem;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    user-select: none;
    touch-action: manipulation;
  }

  @media (hover: hover) {
    .install-strip:hover {
      border-color: light-dark(rgba(0,0,0,0.2), rgba(255,255,255,0.18));
      background: light-dark(#F2F0EC, #131417);
    }
  }

  .dollar { color: var(--text-3); }
  .cmd    { color: var(--text-1); }

  .copy-btn {
    display: flex;
    align-items: center;
    padding: 0.25rem;
    border: none;
    background: transparent;
    color: var(--text-3);
    cursor: pointer;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
    flex-shrink: 0;
    min-width: 40px;
    min-height: 40px;
    justify-content: center;
  }

  @media (hover: hover) {
    .copy-btn:hover {
      color: var(--text-2);
      background: light-dark(rgba(0,0,0,0.06), rgba(255,255,255,0.06));
    }
  }

  .copy-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Primary CTA */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4375rem;
    padding: 0.625rem 1.25rem;
    background: var(--accent);
    color: var(--accent-on);
    text-decoration: none;
    font-family: var(--sans);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    border-radius: 8px;
    transition: background 0.15s, transform 0.12s, opacity 0.15s;
    touch-action: manipulation;
    white-space: nowrap;
  }

  @media (hover: hover) {
    .btn-primary:hover { background: var(--accent-muted); }
  }

  .btn-primary:active { transform: scale(0.97); }

  .btn-primary:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* ─── Terminal section ──────────────────────────────── */
  .hero-terminals {
    width: 100%;
  }

  /* ─── Responsive ────────────────────────────────────── */
  @media (max-width: 640px) {
    .hero {
      padding: 7rem 1.25rem 4rem;
      min-height: auto;
    }

    .install-strip {
      flex-wrap: wrap;
      max-width: 100%;
    }

    .install-strip .cmd {
      font-size: 0.75rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 220px;
    }
  }
</style>

<script>
  const strip  = document.getElementById('install-strip');
  const btn    = document.getElementById('copy-btn');
  const copy   = document.getElementById('icon-copy');
  const check  = document.getElementById('icon-check');

  async function copyInstall() {
    try {
      await navigator.clipboard.writeText('curl -fsSL https://cinchcli.com/install.sh | sh');
      if (copy)  copy.style.display  = 'none';
      if (check) check.style.display = 'block';
      setTimeout(() => {
        if (copy)  copy.style.display  = '';
        if (check) check.style.display = 'none';
      }, 2000);
    } catch (_) {}
  }

  btn?.addEventListener('click', (e) => { e.stopPropagation(); copyInstall(); });
  strip?.addEventListener('click', copyInstall);
  strip?.addEventListener('keydown', (e) => {
    const ke = e as KeyboardEvent;
    if (ke.key === 'Enter' || ke.key === ' ') {
      e.preventDefault();
      copyInstall();
    }
  });

</script>
