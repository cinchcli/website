---
import LiveWire from './LiveWire.astro';
---

<section class="hero section-pad" aria-label="Cinch introduction">
  <div class="container-wide hero-container">
    <div class="hero-content">
      <h1 class="text-display hero-title animate-in" style="--delay: 100ms">
        Your clipboard.<br/>
        <span class="title-muted">Across every machine.</span>
      </h1>

      <p class="hero-description animate-in" style="--delay: 200ms">
        Push from any terminal — pull anywhere.
      </p>

      <div class="hero-actions animate-in" style="--delay: 300ms">
        <div class="hero-ctas">
          <a href="/docs/getting-started/" class="btn-pill btn-primary btn-hero">
            Get started now
            <span class="btn-cta-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </div>

        <div class="hero-secondary">
          <a href="/download" class="secondary-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Download CLI
          </a>
          <span class="separator">/</span>
          <a href="/docs" class="secondary-link">Read the docs</a>
        </div>
      </div>
    </div>

    <div class="hero-visual animate-in" style="--delay: 500ms">
      <LiveWire />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding-top: 12rem;
  }

  .hero-container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 4rem;
  }

  .hero-content {
    max-width: 900px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .badge-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    margin-right: 0.5rem;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.5; }
    100% { transform: scale(1); opacity: 1; }
  }

  .hero-title {
    margin-bottom: 1.5rem;
    text-wrap: balance;
  }

  .title-muted {
    color: var(--text-2);
  }

  .hero-description {
    font-size: 1.25rem;
    color: var(--text-2);
    line-height: 1.6;
    max-width: 60ch;
    margin-bottom: 2.5rem;
    text-wrap: pretty;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-hero {
    padding: 1rem 1.75rem 1rem 1.875rem;
    font-size: 1.0625rem;
    gap: 0.625rem;
  }

  .cta-badge {
    padding: 0.5rem 1.25rem;
    background: light-dark(rgba(36,108,101,0.1), rgba(79,179,169,0.15));
    border-radius: 100px;
    color: var(--accent);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid var(--accent-subtle);
  }

  .hero-secondary {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .secondary-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    color: var(--text-2);
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 4px;
    text-decoration-thickness: 1.5px;
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 8px;
    transition: color 0.3s var(--ease-fluid), text-decoration-color 0.3s var(--ease-fluid), background 0.3s var(--ease-fluid);
  }

  .secondary-link:hover {
    color: var(--text-1);
    text-decoration-color: currentColor;
  }

  .secondary-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .separator {
    color: var(--text-3);
    opacity: 0.5;
    user-select: none;
  }

  .hero-visual {
    width: 100%;
    max-width: 1000px;
  }

  .visual-bezel {
    padding: 0.75rem;
    background: light-dark(rgba(255,255,255,0.5), rgba(0,0,0,0.5));
    backdrop-filter: blur(20px);
  }

  /* ─── Entry Animations ─── */
  .animate-in {
    opacity: 0;
    transform: translateY(2rem);
    animation: slide-up 1s var(--ease-fluid) forwards;
    animation-delay: var(--delay);
  }

  @keyframes slide-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 8rem;
      min-height: auto;
    }
    .hero-container {
      gap: 3rem;
    }
    .hero-description {
      font-size: 1.0625rem;
      margin-bottom: 2rem;
    }
    .hero-ctas {
      width: 100%;
    }
    .btn-hero {
      width: 100%;
      justify-content: center;
    }
    .cta-badge {
      width: 100%;
      text-align: center;
    }
  }

  @media (max-width: 420px) {
    .hero {
      padding-top: 7rem;
    }
    .hero-secondary {
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.25rem;
    }
  }
</style>

