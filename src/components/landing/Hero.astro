---
// Hero — centered: badge → headline → description → CTAs → live demo
import LiveDemo from './LiveDemo.astro';
---

<section class="hero" aria-label="Cinch introduction">

  <!-- Badge -->
  <p class="hero-badge">
    <span class="badge-dot" aria-hidden="true"></span>
    AGPL 3.0 · Open source
  </p>

  <!-- Headline -->
  <h1 class="hero-title">
    Copy from any terminal.
    <span class="title-muted">Paste anywhere.</span>
  </h1>

  <!-- Description -->
  <p class="hero-description">
    Push text, code, or data from any terminal — pull it instantly on any other machine.
    No GUI required.
  </p>

  <!-- CTAs -->
  <div class="hero-actions">
    <div class="hero-ctas">
      <a href="/download" class="cta-download">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download
      </a>
      <a href="/docs/getting-started/" class="cta-docs">
        View docs →
      </a>
    </div>
  </div>

  <!-- Interactive live demo -->
  <div class="hero-terminals">
    <LiveDemo />
  </div>

</section>

<style>
  /* ─── Section ───────────────────────────────────────── */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 5.5rem 2rem 4rem;
    min-height: 100svh;
    max-width: 1100px;
    margin: 0 auto;
    gap: 0;
  }

  /* ─── Badge ─────────────────────────────────────────── */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-3);
    letter-spacing: 0.06em;
    margin-bottom: 1.5rem;
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--border-hover);
    border-radius: 100px;
    background: light-dark(rgba(47,127,120,0.06), rgba(79,179,169,0.07));
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    animation: dot-pulse 2.4s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.72); }
  }

  @media (prefers-reduced-motion: reduce) {
    .badge-dot { animation: none; }
  }

  /* ─── Headline ──────────────────────────────────────── */
  .hero-title {
    /* Use Geist for display: engineered + distinctive, not on blocklist */
    font-family: 'Geist', var(--sans);
    font-size: clamp(2.75rem, 5.5vw, 4.25rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
    color: var(--text-1);
    text-wrap: balance;
    margin-bottom: 1.25rem;
    /* Disable common ligatures on display weight */
    font-feature-settings: 'liga' 0, 'calt' 1;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }

  .title-muted {
    color: var(--text-2);
  }

  /* ─── Description ───────────────────────────────────── */
  .hero-description {
    font-family: var(--sans);
    font-size: 1.0625rem;
    color: var(--text-2);
    line-height: 1.7;
    font-weight: 400;
    letter-spacing: 0.1px;
    max-width: 52ch;
    text-wrap: pretty;
    margin-bottom: 1.75rem;
  }

  /* ─── Actions row ───────────────────────────────────── */
  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 3rem;
    width: 100%;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* Primary download CTA */
  .cta-download {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent);
    color: var(--accent-on);
    font-family: var(--sans);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    padding: 0.75rem 1.375rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
  }

  @media (hover: hover) {
    .cta-download:hover {
      background: var(--accent-muted);
      box-shadow: 0 4px 20px color-mix(in srgb, var(--accent) 28%, transparent);
    }
  }

  .cta-download:active { transform: scale(0.97); }

  .cta-download:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* Secondary docs link */
  .cta-docs {
    font-family: var(--sans);
    font-size: 0.875rem;
    color: var(--text-3);
    text-decoration: none;
    letter-spacing: 0.01em;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: color 0.15s;
  }

  @media (hover: hover) {
    .cta-docs:hover { color: var(--text-2); }
  }

  .cta-docs:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* ─── Terminal section — eye-catching supporting visual ─ */
  .hero-terminals {
    width: 100%;
    max-width: 1040px;
    margin: 0 auto;
  }

  .hero-terminals :global(.term-win) {
    box-shadow:
      0 1px 2px light-dark(rgba(0,0,0,0.05), rgba(0,0,0,0.14)),
      0 6px 16px light-dark(rgba(0,0,0,0.07), rgba(0,0,0,0.20)),
      0 28px 60px -16px light-dark(rgba(0,0,0,0.14), rgba(0,0,0,0.42));
  }

  .hero-terminals :global(.term-body) {
    font-size: 0.9375rem;
    line-height: 1.9;
  }

  /* ─── Responsive ────────────────────────────────────── */
  @media (max-width: 1080px) {
    .hero-terminals :global(.term-body) {
      font-size: 0.875rem;
    }
  }

  @media (max-width: 720px) {
    .hero-terminals :global(.term-body) {
      font-size: 0.8125rem;
      line-height: 1.8;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 7rem 1.25rem 4rem;
      min-height: auto;
    }

    .install-strip {
      max-width: 100%;
      padding: 0.75rem 0.875rem 0.75rem 1rem;
      font-size: 0.8125rem;
    }

    .hero-terminals :global(.term-body) {
      font-size: 0.75rem;
      padding: 0.875rem 1rem 0.75rem;
    }
  }
</style>

