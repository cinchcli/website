---
// Footer component — ultra-minimal, evolu-style
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="footer-copy">
      &copy; {new Date().getFullYear()} Cinch &middot; AGPL 3.0
    </p>

    <nav class="footer-social" aria-label="Social links">
      <a href="https://github.com/JinmuGo/cinch" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    padding: 2rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--text-3);
    letter-spacing: 0.1px;
    margin: 0;
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    color: var(--text-3);
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .social-link:hover {
    color: var(--text-1);
    background: light-dark(rgba(0,0,0,0.05), rgba(255,255,255,0.05));
  }
</style>
