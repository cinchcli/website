---
// LiveDemo — supporting cinematic for the install-focused hero
import TerminalWindow from './TerminalWindow.astro';
const relayBase = import.meta.env.DEV
  ? '/api'
  : 'https://api.cinchcli.com';
---

<div class="live-demo" id="live-demo" data-relay={relayBase}>

  <div class="terminals-row">

    <!-- ── PUSH col ──────────────────────────────────── -->
    <div class="term-col">
      <p class="term-label">PUSH</p>
      <TerminalWindow title="bash — prod-server (ssh)">
        <pre class="term-body"><code><span class="t-c"># SSH'd into prod</span>
<span class="t-p">$</span> <span id="push-echo" class="push-echo">…</span> <span class="t-op">|</span> <span class="t-cmd">cinch push</span>
<span id="push-status" class="push-status"></span></code></pre>
      </TerminalWindow>
    </div>

    <!-- ── Arrow ─────────────────────────────────────── -->
    <div class="flow-arrow" aria-hidden="true">
      <svg width="36" height="36" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M6 16 L22 16 M17 10 L25 16 L17 22"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </div>

    <!-- ── PULL col ──────────────────────────────────── -->
    <div class="term-col">
      <p class="term-label">PULL</p>
      <TerminalWindow title="local-machine — bash">
        <span slot="bar-extra" class="ws-dot" id="ws-dot" title="WebSocket status"></span>
        <pre class="term-body"><code><span class="t-p">$</span> <span class="t-cmd">cinch pull</span>
<span id="pull-output"><span class="t-c">waiting for push…</span></span>
</code></pre>
      </TerminalWindow>
    </div>

  </div>

  <p class="demo-counter" id="demo-counter" aria-live="polite"></p>
</div>

<style>
  /* ── Outer wrapper ─────────────────────────────────── */
  .live-demo {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  /* ── Row ───────────────────────────────────────────── */
  .terminals-row {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: 0;
  }

  /* ── Per-terminal column ───────────────────────────── */
  .term-col {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  /* Stretch the inner terminal frame so both panes share height */
  .term-col :global(.term-win) {
    width: 100%;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .term-col :global(.term-body) {
    flex: 1;
  }

  .term-label {
    font-family: var(--mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-3);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding-left: 1rem;
    margin: 0;
  }

  /* ── Arrow connector ───────────────────────────────── */
  .flow-arrow {
    flex-shrink: 0;
    width: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    align-self: center;
    animation: arrow-pulse 2.8s ease-in-out infinite;
  }

  @keyframes arrow-pulse {
    0%, 100% { opacity: 1;   transform: translateX(0); }
    50%       { opacity: 0.4; transform: translateX(4px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow-arrow { animation: none; }
  }

  /* ── WebSocket status dot ──────────────────────────── */
  .ws-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-left: 4px;
    background: var(--text-3, #6a6b6c);
    transition: background 0.3s;
  }
  .ws-dot.ws-connected    { background: #4ade80; box-shadow: 0 0 6px rgba(74,222,128,0.5); }
  .ws-dot.ws-disconnected { background: light-dark(rgba(0,0,0,0.18), rgba(255,255,255,0.18)); }
  .ws-dot.ws-error        { background: #FF6363; }

  /* ── Push echo / status ────────────────────────────── */
  .push-echo { color: var(--accent); }

  .push-status {
    display: block;
    min-height: 1.3em;
    color: #4ade80;
    transition: opacity 0.2s;
  }
  .push-status.error { color: #FF6363; }

  /* ── Pull output ───────────────────────────────────── */
  #pull-output { display: block; }

  .pull-line {
    display: block;
    color: var(--text-1);
  }
  .pull-line.arriving { color: var(--accent); }

  .pull-receiving {
    display: block;
    color: var(--accent);
    animation: receive-pulse 0.8s ease-in-out infinite;
  }
  @keyframes receive-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.45; }
  }
  @media (prefers-reduced-motion: reduce) {
    .pull-receiving { animation: none; }
  }

  .pull-badge {
    color: var(--text-3);
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
  }
  .pull-clipboard { color: var(--accent); }

  .pull-badge-line {
    display: block;
  }

  /* ── Stats counter ─────────────────────────────────── */
  .demo-counter {
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: var(--text-3);
    letter-spacing: 0.04em;
    text-align: center;
    margin: 0;
    min-height: 1em;
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 720px) {
    .terminals-row {
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
    }
    .flow-arrow {
      transform: rotate(90deg);
      width: 100%;
      height: 2.5rem;
      margin-top: 0;
    }
    @keyframes arrow-pulse {
      0%, 100% { opacity: 1;   transform: rotate(90deg) translateX(0); }
      50%       { opacity: 0.4; transform: rotate(90deg) translateX(4px); }
    }
  }
</style>

<script>
  interface DemoSession {
    token: string;
    stream_id?: string;
    relay_url: string;
    ws_url: string;
    max_clips: number;
    max_bytes: number;
    region?: string;
  }

  interface WSMessage {
    action: string;
    clip?: { content: string; clip_id: string };
  }

  interface PushResponse {
    clip_id: string;
    byte_size: number;
  }

  interface DemoStats {
    pushes_today: number;
  }

  type Scenario = { echo: string; content: string };

  const SCENARIOS: Scenario[] = [
    { echo: 'kubectl get pods | grep api', content: 'api-deployment-7d9f8c8b4-xkj9m' },
  ];

  const RELAY_BASE = (document.getElementById('live-demo') as HTMLElement).dataset.relay ?? 'https://api.cinchcli.com';

  let session: DemoSession | null = null;
  let ws: WebSocket | null = null;
  let pushCount = 0;
  let reconnectAttempts = 0;
  const MAX_RECONNECT = 3;

  let cinematicRunId = 0;
  let cinematicStarted = false;
  let demoRegion = 'us-east';

  const pushEcho   = document.getElementById('push-echo')   as HTMLElement;
  const pushStatus = document.getElementById('push-status') as HTMLElement;
  const pullOutput = document.getElementById('pull-output') as HTMLElement;
  const wsDot      = document.getElementById('ws-dot')      as HTMLElement;
  const counter    = document.getElementById('demo-counter') as HTMLElement;

  function wait(ms: number): Promise<void> {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  async function typewriteAsync(el: HTMLElement, text: string, runId: number): Promise<boolean> {
    for (let i = 0; i <= text.length; i++) {
      if (cinematicRunId !== runId) return false;
      el.textContent = text.slice(0, i) + (i < text.length ? '▌' : '');
      await wait(38);
    }
    return true;
  }

  function resetPullOutput() {
    pullOutput.replaceChildren();
    const waiting = document.createElement('span');
    waiting.className = 't-c';
    waiting.textContent = 'waiting for push…';
    pullOutput.appendChild(waiting);
  }

  async function showPullReceiving(runId: number): Promise<boolean> {
    const waiting = pullOutput.querySelector('.t-c');
    if (waiting) waiting.remove();

    const recv = document.createElement('span');
    recv.className = 'pull-receiving';
    recv.textContent = '↓ receiving…';
    pullOutput.appendChild(recv);

    await wait(450);
    if (cinematicRunId !== runId) {
      recv.remove();
      return false;
    }
    recv.remove();
    return true;
  }

  async function appendClipAnimated(content: string, ms: number, region: string, runId: number): Promise<void> {
    const line = document.createElement('span');
    line.className = 'pull-line arriving';

    line.appendChild(document.createTextNode('> '));

    const text = document.createElement('span');
    line.appendChild(text);

    pullOutput.appendChild(line);
    pullOutput.appendChild(document.createTextNode('\n'));

    // Typewriter the arriving content
    for (let i = 0; i <= content.length; i++) {
      if (cinematicRunId !== runId) return;
      text.textContent = content.slice(0, i);
      await wait(18);
    }

    // Badges go on a continuation line so long content doesn't push them off-screen
    const badgeLine = document.createElement('span');
    badgeLine.className = 'pull-badge-line';
    pullOutput.appendChild(badgeLine);
    pullOutput.appendChild(document.createTextNode('\n'));

    if (ms >= 0 && ms < 1000) {
      const badge = document.createElement('span');
      badge.className = 'pull-badge';
      badge.textContent = `  ↳ ${ms}ms · relay: ${region}`;
      badgeLine.appendChild(badge);
    }

    const clipBadge = document.createElement('span');
    clipBadge.className = 'pull-badge pull-clipboard';
    clipBadge.textContent = ms >= 0 && ms < 1000 ? '  ·  📋 clipboard' : '  ↳ 📋 clipboard';
    badgeLine.appendChild(clipBadge);

    setTimeout(() => line.classList.remove('arriving'), 900);
  }

  async function cinematicPush(content: string, runId: number): Promise<number> {
    if (!session || cinematicRunId !== runId) return 0;
    try {
      const res = await fetch(`${session.relay_url}/clips`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${session.token}`,
        },
        body: JSON.stringify({ content, content_type: 'text' }),
      });
      if (res.ok) {
        const data = await res.json() as PushResponse;
        pushCount++;
        return data.byte_size;
      }
    } catch (_) {}
    return 0;
  }

  async function runCinematic() {
    if (!session) {
      await new Promise<void>(resolve => {
        const t = setTimeout(resolve, 3000);
        const iv = setInterval(() => { if (session) { clearInterval(iv); clearTimeout(t); resolve(); } }, 100);
      });
    }

    while (true) {
      const runId = ++cinematicRunId;

      for (const scenario of SCENARIOS) {
        if (cinematicRunId !== runId) return;
        if (session && pushCount >= session.max_clips) return;

        pushEcho.textContent = '';
        pushStatus.textContent = '';
        pushStatus.className = 'push-status';

        const completed = await typewriteAsync(pushEcho, scenario.echo, runId);
        if (!completed) return;

        await wait(300);
        if (cinematicRunId !== runId) return;

        const pushStart = Date.now();
        const bytes = await cinematicPush(scenario.content, runId);
        if (cinematicRunId !== runId) return;

        const displayBytes = bytes > 0 ? bytes : new Blob([scenario.content]).size;
        pushStatus.textContent = `✓ Pushed ${displayBytes} B`;
        await wait(280);
        if (cinematicRunId !== runId) return;

        const ok = await showPullReceiving(runId);
        if (!ok) return;

        const measuredMs = bytes > 0 ? Date.now() - pushStart : 38;
        await appendClipAnimated(scenario.content, measuredMs, demoRegion, runId);
        if (cinematicRunId !== runId) return;

        await wait(2400);
        if (cinematicRunId !== runId) return;

        pushStatus.textContent = '';
        pushEcho.textContent = '…';
      }

      // Reset before replaying so the loop reads cleanly
      await wait(2000);
      if (cinematicRunId !== runId) return;
      if (session && pushCount >= session.max_clips) return;
      resetPullOutput();
      await wait(800);
    }
  }

  function startCinematic() {
    if (cinematicStarted) return;
    cinematicStarted = true;
    runCinematic();
  }

  function setWS(status: 'connected' | 'disconnected' | 'error') {
    wsDot.className = `ws-dot ws-${status}`;
    wsDot.title = status === 'connected' ? 'Live — receiving pushes' : status;
  }

  function connectWS(wsURL: string, token: string) {
    const url = `${wsURL}?token=${encodeURIComponent(token)}`;
    ws = new WebSocket(url);

    ws.onopen  = () => { setWS('connected'); reconnectAttempts = 0; };
    ws.onerror = () => setWS('error');

    ws.onclose = () => {
      setWS('disconnected');
      if (reconnectAttempts < MAX_RECONNECT) {
        const delay = Math.pow(2, reconnectAttempts) * 1000;
        reconnectAttempts++;
        setTimeout(() => initDemo(), delay);
      } else {
        wsDot.title = 'Connection lost — reload to try again';
      }
    };

    ws.onmessage = (evt: MessageEvent) => {
      // Cinematic drives the pull terminal; WS is just live-status indicator.
      // Parse to keep the wire format honest, but do not double-render.
      try { JSON.parse(evt.data as string); } catch (_) {}
    };
  }

  async function initDemo() {
    try {
      const res = await fetch(`${RELAY_BASE}/demo/session`, { method: 'POST' });
      if (!res.ok) return;
      session = await res.json() as DemoSession;
      demoRegion = session.region ?? 'us-east';
      pushCount = 0;
      connectWS(session.ws_url, session.token);
    } catch (_) {
      setWS('error');
    }
  }

  async function fetchStats() {
    try {
      const res = await fetch(`${RELAY_BASE}/demo/stats`);
      if (!res.ok) return;
      const data = await res.json() as DemoStats;
      if (data.pushes_today > 0) {
        counter.textContent = `✦ ${data.pushes_today.toLocaleString()} developers tried this today`;
      }
    } catch (_) {}
  }

  initDemo();
  fetchStats();

  if (typeof IntersectionObserver !== 'undefined') {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          startCinematic();
          observer.disconnect();
        }
      });
    }, { threshold: 0.3 });
    observer.observe(document.getElementById('live-demo')!);
  } else {
    setTimeout(startCinematic, 800);
  }
</script>
