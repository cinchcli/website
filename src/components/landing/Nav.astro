---
import lockupDark  from '../../assets/lockup-dark-icon.svg';
import lockupLight from '../../assets/lockup-light-icon.svg';
---

<nav id="nav" aria-label="Main navigation">
  <a href="/" class="nav-logo" aria-label="Cinch home">
    <img src={lockupDark.src}  width="24" height="27" alt="" aria-hidden="true" class="logo-dark">
    <img src={lockupLight.src} width="24" height="27" alt="" aria-hidden="true" class="logo-light">
    <span>cinch</span>
  </a>

  <div class="nav-links" id="nav-links">
    <a href="/docs/" class="nav-link">Docs</a>
    <a href="/guides/" class="nav-link">Guides</a>
    <a href="https://github.com/JinmuGo/cinch/releases" class="nav-link" target="_blank" rel="noopener noreferrer">Changelog</a>
    <a href="https://github.com/JinmuGo/cinch" class="nav-icon-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
      <!-- GitHub mark -->
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
      </svg>
    </a>
    <a href="/docs/getting-started/" class="nav-cta">Get Started</a>
  </div>

  <!-- Hamburger — mobile only -->
  <button class="nav-toggle" id="nav-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" aria-controls="nav-links">
    <svg class="icon-menu" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="3" y1="6"  x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
    <svg class="icon-close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
      <line x1="18" y1="6"  x2="6"  y2="18"/>
      <line x1="6"  y1="6"  x2="18" y2="18"/>
    </svg>
  </button>
</nav>

<style>
  /* Show correct logo variant per color scheme */
  .logo-light { display: none; }
  @media (prefers-color-scheme: light) {
    .logo-dark  { display: none; }
    .logo-light { display: inline; }
  }

  #nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    padding: 0 2rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, background 0.3s, backdrop-filter 0.3s;
  }

  #nav.frosted {
    border-color: var(--border);
    background: light-dark(rgba(251,251,250,0.88), rgba(7,8,10,0.88));
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text-1);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.125rem;
  }

  .nav-link {
    padding: 0.375rem 0.75rem;
    color: var(--text-2);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 400;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .nav-link:hover {
    color: var(--text-1);
    background: light-dark(rgba(0,0,0,0.05), rgba(255,255,255,0.05));
  }

  .nav-icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    margin-left: 0.25rem;
    color: var(--text-2);
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    margin-left: 0.5rem;
    padding: 0.375rem 0.875rem;
    background: var(--accent);
    color: var(--accent-on);
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    border-radius: 7px;
    transition: background 0.15s, transform 0.12s;
    white-space: nowrap;
    touch-action: manipulation;
  }

  @media (hover: hover) {
    .nav-cta:hover { background: var(--accent-muted); }
  }

  .nav-cta:active { transform: scale(0.97); }

  .nav-cta:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .nav-icon-link:hover {
    color: var(--text-1);
    background: light-dark(rgba(0,0,0,0.05), rgba(255,255,255,0.05));
  }

  /* ─── HAMBURGER ── hidden on desktop ─────────────────── */
  .nav-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: transparent;
    border: none;
    color: var(--text-2);
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    flex-shrink: 0;
  }

  .nav-toggle:hover {
    color: var(--text-1);
    background: light-dark(rgba(0,0,0,0.05), rgba(255,255,255,0.05));
  }

  /* ─── MOBILE ─────────────────────────────────────────── */
  @media (max-width: 640px) {
    .nav-toggle {
      display: flex;
    }

    .nav-links {
      /* hidden by default, revealed via .open */
      display: none;
      position: absolute;
      top: 3.5rem;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.5rem;
      background: light-dark(rgba(251,251,250,0.96), rgba(7,8,10,0.96));
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border-bottom: 1px solid var(--border);
    }

    .nav-links.open {
      display: flex;
    }

    .nav-link {
      padding: 0.625rem 0.875rem;
      border-radius: 6px;
    }

    .nav-icon-link {
      width: auto;
      height: auto;
      margin-left: 0;
      padding: 0.625rem 0.875rem;
      border-radius: 6px;
      justify-content: flex-start;
      gap: 0.5rem;
    }

    .nav-icon-link::after {
      content: 'GitHub';
      font-size: 0.875rem;
    }
  }
</style>

<script>
  const nav    = document.getElementById('nav');
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement | null;
  const links  = document.getElementById('nav-links');
  const menuIcon = toggle?.querySelector('.icon-menu') as HTMLElement | null;
  const closeIcon = toggle?.querySelector('.icon-close') as HTMLElement | null;

  function updateNav() {
    if (window.scrollY > 8) {
      nav?.classList.add('frosted');
    } else {
      nav?.classList.remove('frosted');
    }
  }

  toggle?.addEventListener('click', () => {
    const open = links?.classList.toggle('open') ?? false;
    toggle.setAttribute('aria-expanded', String(open));
    if (menuIcon)  menuIcon.style.display  = open ? 'none'  : '';
    if (closeIcon) closeIcon.style.display = open ? 'block' : 'none';
  });

  // Close menu when a link is clicked
  links?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      links.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      if (menuIcon)  menuIcon.style.display  = '';
      if (closeIcon) closeIcon.style.display = 'none';
    });
  });

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();
</script>
