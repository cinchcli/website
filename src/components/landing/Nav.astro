---
import lockupDark  from '../../assets/lockup-dark-icon.svg';
import lockupLight from '../../assets/lockup-light-icon.svg';
import { urls } from '../../site/social';
---

<nav class="nav-floating">
  <div class="container-nav">
    <div class="nav-bezel bezel-outer">
      <div class="nav-content bezel-inner">
        <a href="/" class="nav-logo" aria-label="Cinch home">
          <img src={lockupDark.src}  width="24" height="27" alt="" aria-hidden="true" class="logo-dark">
          <img src={lockupLight.src} width="24" height="27" alt="" aria-hidden="true" class="logo-light">
          <span class="logo-text">cinch</span>
        </a>

        <div class="nav-links">
          <a href="/docs/" class="nav-link">Docs</a>
          <a href="/guides/" class="nav-link">Guides</a>
          <a href={urls.githubHome} class="nav-link" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>

        <div class="nav-actions">
          <a href="/docs/getting-started/" class="btn-pill btn-primary btn-cta-compact">
            Get Started
            <span class="btn-cta-icon" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </div>

        <!-- Hamburger — mobile only -->
        <button class="nav-toggle" id="nav-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" aria-controls="nav-links">
          <svg class="icon-menu" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="6"  x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>

<style>
  /* Show correct logo variant per color scheme */
  .logo-light { display: none; }
  @media (prefers-color-scheme: light) {
    .logo-dark  { display: none; }
    .logo-light { display: inline; }
  }

  .nav-floating {
    position: fixed;
    top: 1.5rem;
    left: 0;
    right: 0;
    z-index: 100;
    pointer-events: none;
  }

  .container-nav {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1rem;
    pointer-events: auto;
  }

  .nav-bezel {
    padding: 0.375rem;
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    background: light-dark(rgba(251,251,250,0.6), rgba(5,5,5,0.6));
  }

  .nav-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.5rem 0.5rem 1.5rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: var(--text-1);
    font-size: 1.125rem;
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  .logo-text {
    margin-top: -1px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.5rem 1rem;
    color: var(--text-2);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 100px;
    transition: all 0.3s var(--ease-fluid);
  }

  .nav-link:hover {
    color: var(--text-1);
    background: var(--hover);
  }

  .nav-actions {
    display: flex;
    align-items: center;
  }

  .nav-toggle {
    display: none;
    background: transparent;
    border: none;
    color: var(--text-2);
    cursor: pointer;
    padding: 0.5rem;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
    .nav-actions {
      display: none;
    }
    .nav-toggle {
      display: block;
    }
    .container-nav {
      max-width: 100%;
    }
    .nav-content {
      padding-right: 1rem;
    }
  }
</style>
