---
import lockupDark  from '../../assets/lockup-dark-icon.svg';
import lockupLight from '../../assets/lockup-light-icon.svg';
import { urls } from '../../site/social';
---

<nav class="nav-floating">
  <div class="container-nav">
    <div class="nav-bezel bezel-outer">
      <div class="nav-content bezel-inner">
        <a href="/" class="nav-logo" aria-label="Cinch home">
          <img src={lockupDark.src}  width="24" height="27" alt="" aria-hidden="true" class="logo-dark">
          <img src={lockupLight.src} width="24" height="27" alt="" aria-hidden="true" class="logo-light">
          <span class="logo-text">cinch</span>
        </a>

        <div class="nav-links">
          <a href="/docs/" class="nav-link">Docs</a>
          <a href="/guides/" class="nav-link">Guides</a>
          <a href={urls.githubHome} class="nav-link" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>

        <div class="nav-actions">
          <a href="/docs/getting-started/" class="btn-pill btn-primary btn-cta-compact">
            Get Started
            <span class="btn-cta-icon" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </div>

        <!-- Hamburger — mobile only -->
        <button class="nav-toggle" id="nav-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="nav-mobile-menu">
          <svg class="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" y1="7"  x2="20" y2="7"/>
            <line x1="4" y1="13" x2="20" y2="13"/>
            <line x1="4" y1="19" x2="20" y2="19"/>
          </svg>
          <svg class="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="6" y1="6" x2="18" y2="18"/>
            <line x1="18" y1="6" x2="6" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile drop-down panel (rendered next to .nav-bezel so the same blur/bezel feel carries over) -->
    <div class="nav-mobile" id="nav-mobile-menu" hidden>
      <div class="nav-mobile-bezel bezel-outer">
        <div class="nav-mobile-inner bezel-inner">
          <a href="/docs/" class="nav-mobile-link">Docs</a>
          <a href="/guides/" class="nav-mobile-link">Guides</a>
          <a href={urls.githubHome} class="nav-mobile-link" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="/download" class="nav-mobile-link">Download</a>
          <a href="/docs/getting-started/" class="btn-pill btn-primary nav-mobile-cta">
            Get Started
            <span class="btn-cta-icon" aria-hidden="true">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  /* Show correct logo variant per color scheme */
  .logo-light { display: none; }
  @media (prefers-color-scheme: light) {
    .logo-dark  { display: none; }
    .logo-light { display: inline; }
  }

  .nav-floating {
    position: fixed;
    top: 1.5rem;
    left: 0;
    right: 0;
    z-index: 100;
    pointer-events: none;
  }

  .container-nav {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1rem;
    pointer-events: auto;
  }

  .nav-bezel {
    padding: 0.375rem;
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    background: light-dark(rgba(251,251,250,0.6), rgba(5,5,5,0.6));
  }

  .nav-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.5rem 0.5rem 1.5rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: var(--text-1);
    font-size: 1.125rem;
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  .logo-text {
    margin-top: -1px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.5rem 1rem;
    color: var(--text-2);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 100px;
    transition: all 0.3s var(--ease-fluid);
  }

  .nav-link:hover {
    color: var(--text-1);
    background: var(--hover);
  }

  .nav-actions {
    display: flex;
    align-items: center;
  }

  .nav-toggle {
    display: none;
    background: transparent;
    border: none;
    color: var(--text-2);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 999px;
    transition: color 0.2s var(--ease-fluid), background 0.2s var(--ease-fluid);
    position: relative;
    width: 38px;
    height: 38px;
    align-items: center;
    justify-content: center;
  }

  .nav-toggle:hover {
    color: var(--text-1);
    background: var(--hover);
  }

  .nav-toggle .icon-menu,
  .nav-toggle .icon-close {
    position: absolute;
    inset: 50% auto auto 50%;
    transform: translate(-50%, -50%) scale(1);
    transition: transform 0.25s var(--ease-fluid), opacity 0.2s var(--ease-fluid);
  }
  .nav-toggle .icon-close {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.7) rotate(-45deg);
  }
  .nav-toggle[aria-expanded="true"] .icon-menu {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.7) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .icon-close {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1) rotate(0);
  }

  /* ─── Mobile menu panel ─── */
  .nav-mobile {
    margin-top: 0.5rem;
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.22s var(--ease-fluid), transform 0.22s var(--ease-fluid);
    pointer-events: none;
  }
  .nav-mobile:not([hidden]) {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .nav-mobile[hidden] {
    /* Override the HTML attribute so we can animate. JS toggles a class instead. */
    display: block;
    visibility: hidden;
  }

  .nav-mobile-bezel {
    padding: 0.375rem;
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    background: light-dark(rgba(251,251,250,0.75), rgba(5,5,5,0.75));
  }

  .nav-mobile-inner {
    display: flex;
    flex-direction: column;
    padding: 0.5rem;
    gap: 0.125rem;
  }

  .nav-mobile-link {
    padding: 0.875rem 1rem;
    color: var(--text-2);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    border-radius: 12px;
    transition: color 0.2s var(--ease-fluid), background 0.2s var(--ease-fluid);
  }
  .nav-mobile-link:hover {
    color: var(--text-1);
    background: var(--hover);
  }

  .nav-mobile-cta {
    margin-top: 0.5rem;
    justify-content: center;
    padding: 0.875rem 1.25rem;
    font-size: 0.9375rem;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
    .nav-actions {
      display: none;
    }
    .nav-toggle {
      display: inline-flex;
    }
    .container-nav {
      max-width: 100%;
    }
    .nav-content {
      padding-right: 0.5rem;
    }
  }

  /* Above mobile breakpoint, never show the panel even if state lingers. */
  @media (min-width: 769px) {
    .nav-mobile {
      display: none !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-mobile,
    .nav-toggle .icon-menu,
    .nav-toggle .icon-close {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var toggle = document.getElementById('nav-toggle');
    var panel  = document.getElementById('nav-mobile-menu');
    if (!toggle || !panel) return;

    function setOpen(open) {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      if (open) {
        panel.hidden = false;
        // Force reflow so the CSS transition fires from the hidden start state.
        void panel.offsetWidth;
        document.body.style.overflow = 'hidden';
      } else {
        panel.hidden = true;
        document.body.style.overflow = '';
      }
    }

    toggle.addEventListener('click', function () {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });

    // Close on link tap so in-page nav doesn't leave the menu open behind the next view.
    panel.addEventListener('click', function (e) {
      if (e.target.closest('a')) setOpen(false);
    });

    // Close with Esc for keyboard users.
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });

    // If the viewport grows past the mobile breakpoint while the menu is open,
    // collapse so desktop layout doesn't leak the open state.
    var mq = window.matchMedia('(min-width: 769px)');
    function onMqChange(e) {
      if (e.matches) setOpen(false);
    }
    if (mq.addEventListener) mq.addEventListener('change', onMqChange);
    else if (mq.addListener)  mq.addListener(onMqChange);
  })();
</script>
