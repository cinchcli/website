---
// DualTerminalDemo — static side-by-side push / pull terminals
import TerminalWindow from './TerminalWindow.astro';
---

<div class="dual-demo" aria-label="Push and pull terminal demo">

  <!-- ── PUSH terminal ─────────────────────────────── -->
  <div class="term-wrap">
    <p class="term-label" aria-hidden="true">Push</p>
    <TerminalWindow title="bash — prod-server (ssh)">
      <pre class="term-body"><code
><span class="t-c"># SSH'd into prod</span>
<span class="t-p">$</span> <span class="t-cmd">echo</span> <span class="t-var">$DATABASE_URL</span> <span class="t-op">|</span> <span class="t-cmd">cinch push</span>
<span class="t-ok">✓ Pushed</span>  <span class="t-meta">· relay: us-east · 12ms</span>
</code></pre>
    </TerminalWindow>
  </div>

  <!-- ── ARROW connector ───────────────────────────── -->
  <div class="flow-arrow" aria-hidden="true">
    <svg width="36" height="36" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M6 16 L22 16 M17 10 L25 16 L17 22"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  </div>

  <!-- ── PULL terminal ─────────────────────────────── -->
  <div class="term-wrap">
    <p class="term-label" aria-hidden="true">Pull</p>
    <TerminalWindow title="local-machine — bash">
      <pre class="term-body"><code
><span class="t-c"># Any other machine</span>
<span class="t-p">$</span> <span class="t-cmd">cinch pull</span>
<span class="t-val">postgres://prod:s3cr3t@db.prod.internal/app</span>
<span class="t-meta">  · 📋 clipboard</span>
</code></pre>
    </TerminalWindow>
  </div>

</div>

<style>
  .dual-demo {
    display: flex;
    align-items: flex-end;
    gap: 0;
    width: 100%;
  }

  .term-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-width: 0;
  }

  .term-label {
    font-family: var(--mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-3);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding-left: 1rem;
  }

  .t-var { color: var(--accent); }

  .flow-arrow {
    flex-shrink: 0;
    width: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.5rem;
    color: var(--accent);
    animation: arrow-pulse 2.8s ease-in-out infinite;
  }

  @keyframes arrow-pulse {
    0%, 100% { opacity: 1; transform: translateX(0); }
    50%       { opacity: 0.4; transform: translateX(4px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow-arrow { animation: none; }
  }

  @media (max-width: 680px) {
    .dual-demo {
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
    }
    .flow-arrow {
      transform: rotate(90deg);
      margin-top: 0;
      width: 100%;
      height: 2.5rem;
    }
    @keyframes arrow-pulse {
      0%, 100% { opacity: 1; transform: rotate(90deg) translateX(0); }
      50%       { opacity: 0.4; transform: rotate(90deg) translateX(4px); }
    }
  }
</style>
