---
// Starlight Footer override — adds "Was this page helpful?" before standard footer
import Default from '@astrojs/starlight/components/Footer.astro';

// Suppress the feedback prompt on the 404 page — asking whether a missing page
// was "helpful" is nonsensical.
const entry: { slug?: string; id?: string } | undefined = (Astro.props as any)?.entry;
const slug = entry?.slug ?? entry?.id ?? '';
const isNotFound = slug === '404' || Astro.url.pathname.endsWith('/404') || Astro.url.pathname.endsWith('/404/');
---

{!isNotFound && (
  <div class="page-feedback">
    <p class="feedback-label">Was this page helpful?</p>
    <div class="feedback-buttons">
      <button class="feedback-btn" id="feedback-yes" type="button" aria-label="Yes, this page was helpful">Yes</button>
      <button class="feedback-btn" id="feedback-no"  type="button" aria-label="No, this page was not helpful">No</button>
    </div>
    <span class="feedback-status" id="feedback-status" role="status" aria-live="polite"></span>
  </div>
)}

<Default {...Astro.props} />

<style>
  .page-feedback {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex-wrap: wrap;
    padding: 1.5rem 0;
    margin-bottom: 0.5rem;
    border-top: 1px solid var(--sl-color-hairline);
  }

  .feedback-label {
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  .feedback-buttons {
    display: flex;
    gap: 0.5rem;
  }

  .feedback-btn {
    padding: 0.3125rem 0.875rem;
    border: 1px solid var(--sl-color-hairline);
    border-radius: 6px;
    background: transparent;
    color: var(--sl-color-gray-3);
    font-size: 0.875rem;
    font-family: var(--sl-font);
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .feedback-btn:hover {
    color: var(--sl-color-text-accent);
    border-color: var(--sl-color-text-accent);
    background: var(--sl-color-accent-low);
  }

  .feedback-btn.selected {
    color: var(--sl-color-text-accent);
    border-color: var(--sl-color-text-accent);
    background: var(--sl-color-accent-low);
  }

  .feedback-status {
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
  }
</style>

<script
  is:inline
  define:vars={{
    telemetryUrl: import.meta.env.PUBLIC_TELEMETRY_URL ?? '',
    telemetryKey: import.meta.env.PUBLIC_TELEMETRY_API_KEY ?? '',
  }}
>
  const yes    = document.getElementById('feedback-yes');
  const no     = document.getElementById('feedback-no');
  const status = document.getElementById('feedback-status');

  // Defensive runtime guard: hide the feedback block on the 404 page.
  // Starlight serves the 404 layout on any unknown URL, so the SSR slug
  // check above can't catch dynamic 404 routes — fall back to detecting
  // by the page's own H1 text and og:title meta.
  (function () {
    const h1 = document.querySelector('main h1, .sl-markdown-content h1, h1');
    const og = document.querySelector('meta[property="og:title"]');
    const isNotFound =
      (h1 && h1.textContent && h1.textContent.trim() === '404') ||
      (og && og.getAttribute('content') === '404');
    if (isNotFound) {
      const block = document.querySelector('.page-feedback');
      if (block) block.remove();
    }
  })();

  function sendPageFeedback(helpful) {
    const base = String(telemetryUrl).trim().replace(/\/+$/, '');
    const key = String(telemetryKey).trim();
    if (!base || !key) return;

    const path = typeof location !== 'undefined' ? location.pathname : '';
    const storageKey = `cinch_docs_feedback_sent:${path}`;
    try {
      if (sessionStorage.getItem(storageKey)) return;
    } catch {
      /* private mode / blocked */
    }

    const context = { path };
    if (typeof document !== 'undefined' && document.referrer) {
      context.referrer = document.referrer;
    }

    void fetch(`${base}/v1/events`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-API-Key': key,
      },
      body: JSON.stringify({
        app: 'cinch-website',
        event: 'docs.page_feedback',
        context,
        properties: { helpful },
      }),
    }).catch(() => {});

    try {
      sessionStorage.setItem(storageKey, '1');
    } catch {
      /* ignore */
    }
  }

  function pick(helpful) {
    document.querySelectorAll('.feedback-btn').forEach(b => b.classList.remove('selected'));
    (helpful ? yes : no)?.classList.add('selected');
    if (status) status.textContent = 'Thanks for your feedback!';
    sendPageFeedback(helpful);
  }

  yes?.addEventListener('click', () => pick(true));
  no?.addEventListener('click',  () => pick(false));
</script>
