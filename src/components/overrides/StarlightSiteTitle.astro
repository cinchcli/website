---
// Matches landing Nav logo: 24×27 lockups, lowercase "cinch", primary text color (not accent).
import lockupDark  from '../../assets/lockup-dark-icon.svg';
import lockupLight from '../../assets/lockup-light-icon.svg';

const { siteTitle, siteTitleHref } = Astro.locals.starlightRoute;
---

<a
  href={siteTitleHref}
  class="cinch-site-title sl-flex"
  aria-label={`${siteTitle} home`}
>
  <img
    class="cinch-logo-dark light:sl-hidden print:hidden"
    src={lockupDark.src}
    width={24}
    height={27}
    alt=""
    aria-hidden="true"
  />
  <img
    class="cinch-logo-light dark:sl-hidden print:block"
    src={lockupLight.src}
    width={24}
    height={27}
    alt=""
    aria-hidden="true"
  />
  <span class="cinch-site-title-wordmark" translate="no">cinch</span>
</a>

<style>
  .cinch-site-title {
    align-items: center;
    gap: 0.5rem;
    font-family: var(--sl-font);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--sl-color-gray-1);
    text-decoration: none;
    white-space: nowrap;
    min-width: 0;
  }

  .cinch-site-title-wordmark {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cinch-site-title img {
    flex-shrink: 0;
    width: 24px;
    height: 27px;
    max-width: 100%;
    object-fit: contain;
    object-position: 50% 50%;
  }
</style>
