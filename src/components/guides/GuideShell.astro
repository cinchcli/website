---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'guides'>;
}

const { entry } = Astro.props;
const { title, publishedAt, updatedAt, type } = entry.data;

const formattedPublished = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const formattedUpdated = updatedAt
  ? updatedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const typeLabel: Record<string, string> = {
  compare: 'Comparison',
  'use-case': 'Use Case',
  tutorial: 'Tutorial',
};
---

<div class="guide-page">
  <header class="guide-hero">
    <div class="guide-hero-inner">
      <nav class="breadcrumb mono-caps mono-caps--meta" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Home</a></li>
          <li><a href="/guides/">Guides</a></li>
          <li aria-current="page">{title}</li>
        </ol>
      </nav>
      <p class="mono-caps mono-caps--accent guide-type">{typeLabel[type]}</p>
      <h1 class="guide-title">{title}</h1>
      <p class="byline">
        <time datetime={publishedAt.toISOString()}>{formattedPublished}</time>
        {formattedUpdated && (
          <span> · Updated <time datetime={updatedAt!.toISOString()}>{formattedUpdated}</time></span>
        )}
      </p>
    </div>
  </header>

  <article class="guide-shell">
    <div class="guide-body">
      <slot />
    </div>
  </article>
</div>

<style>
  .guide-page {
    min-height: 100vh;
    padding-top: 3.75rem; /* nav height */
  }

  /* ── Hero header (matches landing section rhythm) ───────── */
  .guide-hero {
    border-bottom: 1px solid var(--border);
  }

  /* Align with landing sections + footer (.footer-inner uses max-width: 1100px; Hero uses same + 2rem horizontal pad) */
  .guide-hero-inner,
  .guide-shell {
    width: 100%;
    max-width: 1100px;
    margin-inline: auto;
    box-sizing: border-box;
    padding-left: max(2rem, env(safe-area-inset-left, 0px));
    padding-right: max(2rem, env(safe-area-inset-right, 0px));
  }

  @media (max-width: 480px) {
    .guide-hero-inner,
    .guide-shell {
      padding-left: max(1.25rem, env(safe-area-inset-left, 0px));
      padding-right: max(1.25rem, env(safe-area-inset-right, 0px));
    }
  }

  .guide-hero-inner {
    padding-top: clamp(4.25rem, 10vw + 2rem, 5.5rem);
    padding-bottom: clamp(1.75rem, 4vw, 2.5rem);
  }

  .breadcrumb ol {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    font-size: 0.875rem;
    letter-spacing: 0.07em;
    color: var(--text-3);
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .breadcrumb li:not(:last-child)::after {
    content: '/';
    margin-left: 0.5rem;
    color: var(--text-3);
    font-weight: 500;
  }

  .breadcrumb a {
    color: var(--text-2);
    text-decoration: none;
    transition: color 0.15s;
  }

  .breadcrumb a:hover { color: var(--accent); }

  .guide-type {
    margin-bottom: 1rem;
  }

  .guide-title {
    font-family: 'Geist', var(--sans);
    font-size: clamp(1.625rem, 4.2vw, 2.75rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--text-1);
    margin-bottom: 0.875rem;
    font-feature-settings: 'liga' 0, 'calt' 1;
    text-wrap: balance;
  }

  .byline {
    font-size: 0.875rem;
    color: var(--text-3);
  }

  /* ── Body ────────────────────────────────────────────────── */
  .guide-shell {
    padding-top: clamp(1.75rem, 5vw, 2.5rem);
    padding-bottom: clamp(4rem, 12vw, 7rem);
  }

  .guide-body {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-1);
  }

  .guide-body :global(h2) {
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 2.75rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-1);
  }

  .guide-body :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: var(--text-1);
  }

  .guide-body :global(p) {
    margin-bottom: 1.25rem;
    color: var(--text-2);
  }

  .guide-body :global(ul),
  .guide-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    color: var(--text-2);
  }

  .guide-body :global(li) {
    margin-bottom: 0.375rem;
    line-height: 1.65;
  }

  .guide-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
    transition: text-decoration-color 0.15s;
  }

  .guide-body :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .guide-body :global(strong) {
    color: var(--text-1);
    font-weight: 600;
  }

  .guide-body :global(code) {
    font-family: var(--mono);
    font-size: 0.875em;
    background: var(--bg-card-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.15em 0.4em;
    /* --accent-pastel is for dark UI tint; on inline chips use theme accent for contrast */
    color: var(--accent);
  }

  .guide-body :global(pre) {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.75rem;
  }

  .guide-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
    color: var(--text-1);
  }

  .guide-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    margin-bottom: 1.75rem;
  }

  .guide-body :global(th) {
    background: var(--bg-card);
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    color: var(--text-2);
    padding: 0.625rem 0.875rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }

  .guide-body :global(td) {
    padding: 0.625rem 0.875rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-2);
    vertical-align: top;
  }

  .guide-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }
</style>
