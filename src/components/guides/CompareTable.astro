---
interface CompareRow {
  feature: string;
  cinch: string;
  competitor: string;
  note?: string;
}

interface Props {
  rows: CompareRow[];
  competitorName: string;
}

const { rows, competitorName } = Astro.props;
---

<div class="compare-wrapper">
  <table class="compare-table">
    <thead>
      <tr>
        <th scope="col">Feature</th>
        <th scope="col" class="cinch-col">Cinch</th>
        <th scope="col">{competitorName}</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          <td>{row.feature}</td>
          <td class="cinch-col">{row.cinch}</td>
          <td>{row.competitor}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .compare-wrapper {
    overflow-x: auto;
    margin: 2rem 0;
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }

  th, td {
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  tr:last-child td {
    border-bottom: none;
  }

  th {
    background: var(--bg-card);
    font-weight: 600;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-2);
  }

  .cinch-col {
    background: var(--accent-subtle);
    color: var(--text-1);
  }

  th.cinch-col {
    color: var(--accent);
  }

  tr:hover td {
    background: var(--hover);
  }

  tr:hover td.cinch-col {
    background: color-mix(in srgb, var(--accent-subtle) 80%, var(--hover));
  }
</style>
