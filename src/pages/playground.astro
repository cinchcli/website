---
import Landing from '../layouts/Landing.astro';
import Nav     from '../components/landing/Nav.astro';
import Footer  from '../components/landing/Footer.astro';

const relayBase = import.meta.env.DEV
  ? '/api'
  : 'https://api.cinchcli.com';
---

<Landing
  title="Cinch Playground — Live Relay Demo"
  description="Push text from any terminal and watch it appear here instantly. This is what cinch does — across your own machines."
>
  <Nav />
  <main class="playground-page">
    <div id="playground" data-relay={relayBase} hidden></div>

    <header class="playground-header">
      <h1 class="playground-title">Cinch Playground</h1>
      <p class="playground-subtitle">
        Run <code class="inline-code">cinch push</code> in any terminal — SSH box, CI, wherever.
        Watch it appear here in real time.
      </p>
      <p class="playground-disclaimer">
        This is a public demo relay. Your personal relay is private.
      </p>
    </header>

    <div class="playground-status">
      <span class="ws-dot ws-disconnected" aria-hidden="true"></span>
      <span class="status-label">Relay</span>
      <span id="playground-countdown" class="countdown">Loading…</span>
    </div>

    <div id="playground-error" hidden class="playground-error" role="status" aria-live="polite"></div>

    <section class="playground-feed-pane" aria-label="Live clip feed">
      <div class="demo-window">
        <div class="demo-bar">
          <span class="dot dot-r"></span>
          <span class="dot dot-y"></span>
          <span class="dot dot-g"></span>
          <span class="demo-label">playground — live</span>
        </div>
        <ul id="playground-feed" class="playground-feed">
          <li class="empty">No clips yet — be the first to push.</li>
        </ul>
      </div>
    </section>

    <section class="playground-curl-pane" aria-label="Try cinch">
      <!-- Primary CTA: cinch CLI -->
      <div class="curl-block curl-block--primary">
        <header class="curl-header">
          <span class="curl-title">Push with cinch CLI</span>
          <button
            class="copy-btn"
            type="button"
            data-target="playground-curl-write"
            aria-label="Copy cinch push command"
          >⎘</button>
        </header>
        <pre class="curl-pre"><code id="playground-curl-write" class="curl-code">Loading…</code></pre>
        <p class="curl-note">
          No cinch yet? →
          <a href="https://cinchcli.com/docs/quick-start/" class="curl-link">Install in 30 seconds</a>
        </p>
      </div>

      <!-- Secondary: curl fallback for zero-install demo -->
      <div class="curl-block curl-block--secondary">
        <header class="curl-header">
          <span class="curl-title">Or try instantly with curl</span>
          <button
            class="copy-btn"
            type="button"
            data-target="playground-curl-read"
            aria-label="Copy curl command"
          >⎘</button>
        </header>
        <pre class="curl-pre"><code id="playground-curl-read" class="curl-code">Loading…</code></pre>
      </div>
    </section>
  </main>
  <Footer />
</Landing>

<style>
  /* ── Page-level layout ─────────────────────────────── */
  .playground-page {
    max-width: 880px;
    margin: 0 auto;
    padding: 6rem 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* ── Header block ──────────────────────────────────── */
  .playground-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .playground-title {
    font-family: var(--sans);
    font-size: 2.5rem;
    font-weight: 600;
    letter-spacing: 0;
    color: var(--text-1);
    margin: 0;
    line-height: 1.1;
    text-wrap: balance;
  }

  .playground-subtitle {
    font-family: var(--sans);
    font-size: 1.0625rem;
    font-weight: 400;
    color: var(--text-2);
    letter-spacing: 0.2px;
    margin: 0;
    line-height: 1.4;
  }

  .playground-disclaimer {
    font-family: var(--sans);
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--text-3);
    letter-spacing: 0.2px;
    margin-top: 0.25rem;
  }

  /* ── Status row ────────────────────────────────────── */
  .playground-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text-3);
    letter-spacing: 0.04em;
  }

  .status-label {
    color: var(--text-2);
  }

  .countdown {
    margin-left: auto;
    color: var(--text-2);
  }

  /* ── Terminal window shell (verbatim from LiveDemo.astro) ── */
  .demo-window {
    background: light-dark(#F7F6F3, #0e0f11);
    border: 1px solid var(--border-hover);
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 24px 64px -16px light-dark(rgba(0,0,0,0.10), rgba(0,0,0,0.7)),
      0 0 0 1px light-dark(rgba(0,0,0,0.05), rgba(255,255,255,0.02)),
      inset 0 1px 0 light-dark(rgba(255,255,255,0.8), rgba(255,255,255,0.04));
  }

  .demo-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--border);
    background: light-dark(rgba(0,0,0,0.02), rgba(255,255,255,0.015));
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-r { background: #ff5f57; }
  .dot-y { background: #febc2e; }
  .dot-g { background: #28c840; }

  .demo-label {
    margin-left: auto;
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: var(--text-3);
    letter-spacing: 0.04em;
  }

  /* ── WebSocket status dot (verbatim from LiveDemo.astro) ── */
  .ws-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--text-3, #6a6b6c);
    transition: background 0.3s;
  }
  .ws-dot.ws-connected    { background: #4ade80; box-shadow: 0 0 6px rgba(74,222,128,0.5); }
  .ws-dot.ws-disconnected { background: light-dark(rgba(0,0,0,0.18), rgba(255,255,255,0.18)); }
  .ws-dot.ws-error        { background: #FF6363; }

  /* ── Feed list ─────────────────────────────────────── */
  .playground-feed {
    list-style: none;
    margin: 0;
    padding: 1rem 1.375rem;
    font-family: var(--mono);
    font-size: 0.8125rem;
    line-height: 1.6;
    min-height: 14rem;
    max-height: 28rem;
    overflow-y: auto;
    color: var(--text-1);
  }

  .playground-feed li {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.125rem 0;
  }

  .playground-feed .prompt {
    color: var(--accent);
    flex-shrink: 0;
    user-select: none;
  }

  .playground-feed .content {
    flex: 1;
    word-break: break-word;
    white-space: pre-wrap;
  }

  .playground-feed .ago {
    color: var(--text-3);
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  .playground-feed li.empty {
    font-style: italic;
    color: var(--text-3);
  }

  /* ── Inline code in subtitle ───────────────────────── */
  .inline-code {
    font-family: var(--mono);
    font-size: 0.9em;
    color: var(--accent);
    background: var(--accent-subtle);
    border-radius: 3px;
    padding: 0.1em 0.35em;
  }

  /* ── Curl pane ─────────────────────────────────────── */
  .playground-curl-pane {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .curl-block {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-card);
    overflow: hidden;
  }

  .curl-block--primary {
    border-color: var(--accent-muted);
  }

  .curl-block--secondary {
    opacity: 0.75;
  }

  .curl-note {
    font-family: var(--sans);
    font-size: 0.75rem;
    color: var(--text-3);
    margin: 0;
    padding: 0.5rem 1rem 0.75rem;
    border-top: 1px solid var(--border);
  }

  .curl-link {
    color: var(--accent);
    text-decoration: none;
  }
  .curl-link:hover {
    text-decoration: underline;
  }

  .curl-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.875rem;
    border-bottom: 1px solid var(--border);
    background: light-dark(rgba(0,0,0,0.02), rgba(255,255,255,0.015));
  }

  .curl-title {
    font-family: var(--sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-2);
    letter-spacing: 0.02em;
  }

  .copy-btn {
    background: none;
    border: 1px solid var(--border-hover);
    border-radius: 4px;
    color: var(--text-3);
    cursor: pointer;
    font-family: var(--mono);
    font-size: 0.875rem;
    line-height: 1;
    padding: 0.125rem 0.5rem;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }

  .copy-btn:hover {
    color: var(--text-1);
    border-color: var(--text-3);
    background: var(--accent-subtle);
  }

  .curl-pre {
    margin: 0;
    padding: 0.875rem 1rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    line-height: 1.6;
    color: var(--text-1);
    overflow-x: auto;
    background: transparent;
  }

  .curl-code {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
    white-space: pre;
    font-size: inherit;
  }

  /* ── Error state ───────────────────────────────────── */
  .playground-error {
    padding: 0.875rem 1rem;
    border-left: 3px solid #FF6363;
    background: light-dark(rgba(255,99,99,0.06), rgba(255,99,99,0.10));
    border-radius: 4px;
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--text-1);
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 640px) {
    .playground-page {
      padding: 5rem 1rem 3rem;
    }
    .playground-title {
      font-size: 2rem;
    }
  }
</style>

<script>
  interface PlaygroundSession {
    token: string;
    stream_id: string;
    relay_url: string;
    ws_url: string;
    expires_at: string; // ISO-8601
    region: string;
  }

  interface WSClipPayload { content: string; clip_id?: string; }
  interface WSMessage     { action: string; clip?: WSClipPayload; }

  const MAX_CLIPS = 20;
  const TRUNCATE_AT = 200;
  const RECONNECT_DELAY_MS = 2000;
  const ERROR_COPY = 'Demo relay is offline. Try again in a moment.';

  const root = document.getElementById('playground') as HTMLDivElement | null;
  const RELAY_BASE = root?.dataset.relay ?? 'https://api.cinchcli.com';

  const feedEl       = document.getElementById('playground-feed') as HTMLUListElement;
  const countdownEl  = document.getElementById('playground-countdown') as HTMLElement;
  const errorEl      = document.getElementById('playground-error') as HTMLElement;
  const wsDotEl      = document.querySelector('.ws-dot') as HTMLElement;
  const readCmdEl    = document.getElementById('playground-curl-read')  as HTMLElement;
  const writeCmdEl   = document.getElementById('playground-curl-write') as HTMLElement;

  interface FeedItem { content: string; receivedAt: number; }
  let session: PlaygroundSession | null = null;
  let ws: WebSocket | null = null;
  let countdownInterval: ReturnType<typeof setInterval> | null = null;
  let agoInterval: ReturnType<typeof setInterval> | null = null;
  const items: FeedItem[] = [];
  let reconnecting = false;

  function setWS(state: 'connected' | 'disconnected' | 'error'): void {
    wsDotEl.classList.remove('ws-connected', 'ws-disconnected', 'ws-error');
    wsDotEl.classList.add(`ws-${state}`);
  }

  function showError(): void {
    errorEl.textContent = ERROR_COPY;
    errorEl.removeAttribute('hidden');
  }
  function clearError(): void {
    errorEl.textContent = '';
    errorEl.setAttribute('hidden', '');
  }

  function clearFeed(): void {
    items.length = 0;
    renderFeed();
  }

  function addItem(content: string): void {
    const truncated = content.length > TRUNCATE_AT
      ? content.slice(0, TRUNCATE_AT) + '…'
      : content;
    items.unshift({ content: truncated, receivedAt: Date.now() });
    if (items.length > MAX_CLIPS) items.length = MAX_CLIPS;
    renderFeed();
  }

  function renderFeed(): void {
    feedEl.replaceChildren();
    if (items.length === 0) {
      const li = document.createElement('li');
      li.className = 'empty';
      li.textContent = 'No clips yet — be the first to push.';
      feedEl.appendChild(li);
      return;
    }
    for (const it of items) {
      const li = document.createElement('li');

      const prompt = document.createElement('span');
      prompt.className = 'prompt';
      prompt.textContent = '>';

      const content = document.createElement('span');
      content.className = 'content';
      content.textContent = it.content; // MUST be textContent — never innerHTML

      const ago = document.createElement('span');
      ago.className = 'ago';
      ago.dataset.received = String(it.receivedAt);
      ago.textContent = formatAgo(it.receivedAt);

      li.appendChild(prompt);
      li.appendChild(content);
      li.appendChild(ago);
      feedEl.appendChild(li);
    }
  }

  function formatAgo(receivedAt: number): string {
    const seconds = Math.max(0, Math.floor((Date.now() - receivedAt) / 1000));
    if (seconds < 60) return `· ${seconds}s ago`;
    const m = Math.floor(seconds / 60);
    return `· ${m}m ago`;
  }

  function refreshAgoLabels(): void {
    const labels = feedEl.querySelectorAll<HTMLElement>('.ago');
    labels.forEach((el) => {
      const r = Number(el.dataset.received ?? 0);
      if (r) el.textContent = formatAgo(r);
    });
  }

  function startCountdown(expiresAt: string): void {
    if (countdownInterval) clearInterval(countdownInterval);
    const tick = (): void => {
      const remaining = new Date(expiresAt).getTime() - Date.now();
      if (remaining <= 0) {
        countdownEl.textContent = 'Board resetting…';
        if (countdownInterval) clearInterval(countdownInterval);
        return;
      }
      const m = Math.floor(remaining / 60000);
      const s = Math.floor((remaining % 60000) / 1000);
      countdownEl.textContent = `Board resets in ${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
    };
    tick();
    countdownInterval = setInterval(tick, 1000);
  }

  function renderCurlCommands(s: PlaygroundSession): void {
    // Primary: cinch CLI — shows the actual product value prop
    writeCmdEl.textContent = `# Push from any terminal (SSH box, CI, anywhere)
echo "hello from $(hostname)" | cinch push`;

    // Secondary: curl fallback — zero-install path using the shared demo relay
    readCmdEl.textContent = `curl -X POST "${s.relay_url}/demo/playground/push" \\
  -H "Content-Type: application/json" \\
  -d '{"content":"hello from curl","content_type":"text"}'`;
  }

  function connectWS(wsURL: string, token: string): void {
    if (ws) {
      try { ws.close(); } catch (_) { /* ignore */ }
    }
    const url = new URL(wsURL);
    // Browsers block ws:// from an https:// page (mixed content). Upgrade
    // defensively so a relay that misreports its public scheme still works.
    if (window.location.protocol === 'https:' && url.protocol === 'ws:') {
      url.protocol = 'wss:';
    }
    url.searchParams.set('token', token);
    ws = new WebSocket(url.toString());

    ws.addEventListener('open',  () => { setWS('connected'); clearError(); });
    ws.addEventListener('error', () => { setWS('error'); });
    ws.addEventListener('close', () => {
      setWS('disconnected');
      scheduleReconnect();
    });
    ws.addEventListener('message', (ev: MessageEvent<string>) => {
      try {
        const msg = JSON.parse(ev.data) as WSMessage;
        if (msg.clip && typeof msg.clip.content === 'string') {
          addItem(msg.clip.content);
        }
      } catch (_) { /* ignore non-JSON */ }
    });
  }

  function scheduleReconnect(): void {
    if (reconnecting) return;
    reconnecting = true;
    clearFeed();
    setTimeout(() => {
      reconnecting = false;
      void initPlayground();
    }, RECONNECT_DELAY_MS);
  }

  async function initPlayground(): Promise<void> {
    try {
      const res = await fetch(`${RELAY_BASE}/demo/playground`);
      if (!res.ok) { showError(); setWS('error'); return; }
      session = (await res.json()) as PlaygroundSession;
      clearError();
      startCountdown(session.expires_at);
      renderCurlCommands(session);
      connectWS(session.ws_url, session.token);
    } catch (_) {
      showError();
      setWS('error');
    }
  }

  // Copy buttons (mirror LiveDemo.astro pattern)
  const copyButtons = document.querySelectorAll<HTMLButtonElement>('.copy-btn');
  copyButtons.forEach((btn) => {
    btn.addEventListener('click', async () => {
      const targetId = btn.dataset.target ?? '';
      const targetEl = document.getElementById(targetId);
      const text = targetEl?.textContent ?? '';
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent ?? '⎘';
        btn.textContent = '✓';
        setTimeout(() => { btn.textContent = original; }, 1500);
      } catch (_) { /* clipboard blocked — silently ignore */ }
    });
  });

  // Refresh "Ns ago" labels every second
  agoInterval = setInterval(refreshAgoLabels, 1000);
  // Reference agoInterval to satisfy noUnusedLocals if enabled
  void agoInterval;

  // Render the empty state immediately so the page is not blank during fetch
  renderFeed();

  void initPlayground();
</script>
