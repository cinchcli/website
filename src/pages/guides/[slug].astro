---
import { getCollection, render } from 'astro:content';
import Landing from '../../layouts/Landing.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';
import GuideShell from '../../components/guides/GuideShell.astro';
import CompareTable from '../../components/guides/CompareTable.astro';
import HowToSteps from '../../components/guides/HowToSteps.astro';
import FaqList from '../../components/guides/FaqList.astro';
import { buildGuideJsonLd } from '../../lib/seo/guide-jsonld';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  return guides.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const canonical = entry.data.canonical ?? new URL(`/guides/${entry.id}/`, Astro.site).href;
const jsonLd = buildGuideJsonLd(entry, Astro.site!);
---

<Landing
  title={entry.data.title}
  description={entry.data.description}
  canonical={canonical}
  ogType="article"
  ogImage={entry.data.ogImage}
  noindex={entry.data.noindex}
  jsonLd={jsonLd}
>
  <Nav />
  <GuideShell entry={entry}>
    {entry.data.type === 'compare' && entry.data.competitor && entry.data.competitor.rows.length > 0 && (
      <CompareTable rows={entry.data.competitor.rows} competitorName={entry.data.competitor.name} />
    )}
    <Content />
    {entry.data.steps && entry.data.steps.length > 0 && (
      <HowToSteps steps={entry.data.steps} />
    )}
    {entry.data.faqs && entry.data.faqs.length > 0 && (
      <FaqList faqs={entry.data.faqs} />
    )}
  </GuideShell>
  <Footer />
</Landing>
