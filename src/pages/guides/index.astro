---
import { getCollection } from 'astro:content';
import Landing from '../../layouts/Landing.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';

const guides = await getCollection('guides', ({ data }) => !data.draft);

const byType = {
  compare: guides.filter((g) => g.data.type === 'compare'),
  'use-case': guides.filter((g) => g.data.type === 'use-case'),
  tutorial: guides.filter((g) => g.data.type === 'tutorial'),
};

const sections: { type: 'compare' | 'use-case' | 'tutorial'; label: string; description: string }[] = [
  { type: 'compare', label: 'Comparisons', description: 'How Cinch stacks up against other clipboard tools.' },
  { type: 'use-case', label: 'Use Cases', description: 'Solve specific clipboard problems in your workflow.' },
  { type: 'tutorial', label: 'Tutorials', description: 'Step-by-step guides for common setups.' },
];

const canonical = new URL('/guides/', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  url: canonical,
  name: 'Cinch Guides',
  description: 'Comparisons, use-case guides, and tutorials for Cinch — the remote clipboard tool for developers.',
  publisher: { '@type': 'Organization', name: 'Cinch', url: Astro.site?.href },
};
---

<Landing
  title="Guides — Cinch"
  description="Comparisons, use-case guides, and tutorials for Cinch — the remote clipboard tool for developers."
  canonical={canonical}
  jsonLd={jsonLd}
>
  <Nav />
  <main id="main-content" class="guides-index">
    <header class="index-header">
      <h1>Guides</h1>
      <p class="subtitle">Everything you need to get the most out of Cinch — comparisons, use cases, and step-by-step tutorials.</p>
    </header>

    {sections.map(({ type, label, description }) => byType[type].length > 0 && (
      <section class="guide-section">
        <h2>{label}</h2>
        <p class="section-desc">{description}</p>
        <ul class="guide-grid">
          {byType[type].map((guide) => (
            <li>
              <a href={`/guides/${guide.id}/`} class="guide-card">
                <span class="card-title">{guide.data.title}</span>
                <span class="card-desc">{guide.data.description}</span>
                <span class="card-cta">Read guide →</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </main>
  <Footer />
</Landing>

<style>
  .guides-index {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .index-header {
    margin-bottom: 3.5rem;
    text-align: center;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--text-1);
    margin-bottom: 0.75rem;
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--text-2);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .guide-section {
    margin-bottom: 3.5rem;
  }

  h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-1);
    margin-bottom: 0.375rem;
  }

  .section-desc {
    font-size: 0.9375rem;
    color: var(--text-2);
    margin-bottom: 1.25rem;
  }

  .guide-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    padding: 0;
  }

  .guide-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
    height: 100%;
  }

  .guide-card:hover {
    border-color: var(--border-hover);
    background: var(--hover);
  }

  .card-title {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--text-1);
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.875rem;
    color: var(--text-2);
    line-height: 1.55;
    flex: 1;
  }

  .card-cta {
    font-size: 0.8125rem;
    color: var(--accent);
    font-weight: 500;
    margin-top: auto;
  }
</style>
