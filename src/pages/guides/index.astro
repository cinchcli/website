---
import { getCollection } from 'astro:content';
import Landing from '../../layouts/Landing.astro';
import Nav from '../../components/landing/Nav.astro';
import Footer from '../../components/landing/Footer.astro';

const guides = await getCollection('guides', ({ data }) => !data.draft);

const byType = {
  compare: guides.filter((g) => g.data.type === 'compare'),
  'use-case': guides.filter((g) => g.data.type === 'use-case'),
  tutorial: guides.filter((g) => g.data.type === 'tutorial'),
};

const guideTypeLabel: Record<'compare' | 'use-case' | 'tutorial', string> = {
  compare: 'Comparison',
  'use-case': 'Use Case',
  tutorial: 'Tutorial',
};

const sections: { type: 'compare' | 'use-case' | 'tutorial'; label: string; description: string }[] = [
  { type: 'compare', label: 'Comparisons', description: 'How Cinch stacks up against other clipboard tools.' },
  { type: 'use-case', label: 'Use Cases', description: 'Solve specific clipboard problems in your workflow.' },
  { type: 'tutorial', label: 'Tutorials', description: 'Step-by-step guides for common setups.' },
];

const canonical = new URL('/guides/', Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  url: canonical,
  name: 'Cinch Guides',
  description: 'Comparisons, use-case guides, and tutorials for Cinch — the remote clipboard tool for developers.',
  publisher: { '@type': 'Organization', name: 'Cinch', url: Astro.site?.href },
};
---

<Landing
  title="Guides — Cinch"
  description="Comparisons, use-case guides, and tutorials for Cinch — the remote clipboard tool for developers."
  canonical={canonical}
  jsonLd={jsonLd}
>
  <Nav />
  <div class="guides-page">
    <div class="guides-layout">
      <header class="guides-hero" aria-labelledby="guides-heading">
        <nav class="guides-breadcrumb mono-caps mono-caps--meta" aria-label="Breadcrumb">
          <ol>
            <li><a href="/">Home</a></li>
            <li aria-current="page">Guides</li>
          </ol>
        </nav>
        <h1 class="guides-title" id="guides-heading">
          <span class="guides-title-line">Learn Cinch</span>
          <span class="guides-title-muted">by example.</span>
        </h1>
        <p class="guides-lead">
          Comparisons, workflow recipes, and tutorials — same stack as the homepage: terminal-first,
          self-hostable, real-time.
        </p>
        <div class="guides-actions">
          <a href="/docs/getting-started/" class="guides-cta-docs">View docs →</a>
        </div>
      </header>

      {sections.map(({ type, label, description }) => byType[type].length > 0 && (
        <section class="guides-section" aria-labelledby={`guides-cat-${type}`}>
          <div class="guides-section-head">
            <h2 class="guides-section-title" id={`guides-cat-${type}`}>{label}</h2>
            <p class="guides-section-desc">{description}</p>
          </div>
          <ul class="guides-grid" role="list">
            {byType[type].map((guide) => (
              <li>
                <a href={`/guides/${guide.id}/`} class="guide-card">
                  <span class="card-type">{guideTypeLabel[guide.data.type]}</span>
                  <span class="card-title">{guide.data.title}</span>
                  <span class="card-desc">{guide.data.description}</span>
                  <span class="card-cta" aria-hidden="true">Read guide →</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
  <Footer />
</Landing>

<style>
  .guides-page {
    min-height: 100vh;
    padding-top: 3.75rem;
  }

  .guides-layout {
    max-width: 1100px;
    margin: 0 auto;
    padding-left: max(2rem, env(safe-area-inset-left, 0px));
    padding-right: max(2rem, env(safe-area-inset-right, 0px));
    padding-bottom: clamp(4rem, 12vw, 7rem);
    box-sizing: border-box;
  }

  @media (max-width: 480px) {
    .guides-layout {
      padding-left: max(1.25rem, env(safe-area-inset-left, 0px));
      padding-right: max(1.25rem, env(safe-area-inset-right, 0px));
    }
  }

  /* ── Hero (rhythm aligned with GuideShell guide-hero) ───── */
  .guides-hero {
    border-bottom: 1px solid var(--border);
    padding-top: clamp(2rem, 5vw, 3rem);
    padding-bottom: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: clamp(2.5rem, 6vw, 3.5rem);
  }

  .guides-breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    font-size: 0.875rem;
    letter-spacing: 0.07em;
    color: var(--text-3);
    margin-bottom: 1rem;
  }

  .guides-breadcrumb li:not(:last-child)::after {
    content: '/';
    margin-left: 0.5rem;
    color: var(--text-3);
    font-weight: 500;
  }

  .guides-breadcrumb a {
    color: var(--text-2);
    text-decoration: none;
    transition: color 0.15s;
  }

  .guides-breadcrumb a:hover {
    color: var(--accent);
  }

  .guides-title {
    font-family: 'Geist', var(--sans);
    font-size: clamp(2.125rem, 4.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.035em;
    color: var(--text-1);
    margin-bottom: 1.25rem;
    font-feature-settings: 'liga' 0, 'calt' 1;
    display: flex;
    flex-direction: column;
    gap: 0.06em;
    text-wrap: balance;
    max-width: min(42rem, 100%);
  }

  .guides-title-line {
    display: block;
    color: var(--text-1);
  }

  .guides-title-muted {
    display: block;
    color: var(--text-2);
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .guides-lead {
    font-size: 1.0625rem;
    color: var(--text-2);
    line-height: 1.75;
    letter-spacing: 0.2px;
    max-width: 52ch;
    margin-bottom: 1.35rem;
  }

  .guides-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  .guides-cta-docs {
    font-family: var(--sans);
    font-size: 0.875rem;
    color: var(--text-3);
    text-decoration: none;
    letter-spacing: 0.01em;
    padding: 0.35rem 0.65rem;
    margin-left: -0.65rem;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  @media (hover: hover) {
    .guides-cta-docs:hover {
      color: var(--text-2);
      background: light-dark(rgba(0, 0, 0, 0.04), rgba(255, 255, 255, 0.06));
    }
  }

  .guides-cta-docs:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* ── Sections ────────────────────────────────────────────── */
  .guides-section {
    margin-bottom: clamp(3rem, 8vw, 4rem);
  }

  .guides-section:last-child {
    margin-bottom: 0;
  }

  .guides-section-head {
    margin-bottom: 1.25rem;
    max-width: 42rem;
  }

  .guides-section-title {
    font-family: 'Geist', var(--sans);
    font-size: clamp(1.375rem, 2.75vw, 1.875rem);
    font-weight: 700;
    letter-spacing: -0.028em;
    line-height: 1.15;
    color: var(--text-1);
    margin-bottom: 0.5rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--border);
  }

  .guides-section-desc {
    font-size: 0.9375rem;
    color: var(--text-2);
    line-height: 1.65;
    margin-top: 0.65rem;
  }

  /* ── Card grid ───────────────────────────────────────────── */
  .guides-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 288px), 1fr));
    gap: 1rem;
    padding: 0;
    margin: 0;
  }

  .guides-grid > li {
    display: flex;
    min-height: 0;
  }

  .guide-card {
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.5rem;
    padding: 1.35rem 1.4rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    min-height: 100%;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease;
  }

  @media (hover: hover) {
    .guide-card:hover {
      border-color: var(--border-hover);
      background: var(--bg-card-2);
      box-shadow: 0 1px 0 rgba(255, 255, 255, 0.04);
    }
  }

  @media (prefers-color-scheme: light) {
    @media (hover: hover) {
      .guide-card:hover {
        box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
      }
    }
  }

  .guide-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .guide-card:hover .card-title {
    color: var(--accent);
  }

  .guide-card:hover .card-cta {
    color: var(--accent-muted);
  }

  .card-type {
    font-family: var(--mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.15rem;
  }

  .card-title {
    font-weight: 600;
    font-size: 1.0625rem;
    color: var(--text-1);
    line-height: 1.35;
    letter-spacing: -0.015em;
    transition: color 0.15s;
  }

  .card-desc {
    font-size: 0.9375rem;
    color: var(--text-2);
    line-height: 1.6;
    flex: 1;
  }

  .card-cta {
    font-family: var(--mono);
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 500;
    margin-top: 0.35rem;
    transition: color 0.15s;
  }
</style>
